# HeyGen LiveAvatar — copy this file to .env and fill in the two values marked "FILL IN".

# Secret API key — server-side ONLY, never exposed to the browser. FILL IN.
LIVEAVATAR_API_KEY=

# "Alessandra" avatar + her Italian voice (provided defaults, no need to change).
LIVEAVATAR_AVATAR_ID=ab0765ad-69de-41fb-9f8a-bd01c3c52d6f
LIVEAVATAR_VOICE_ID=c84af063-5ce2-4370-8ef8-dcd0ef903d43

# Context id — REQUIRED. Without it she connects but stays silent.
# Generate one with `npm run setup`, then paste the printed id here. FILL IN.
LIVEAVATAR_CONTEXT_ID=

# Conversation language.
LIVEAVATAR_LANGUAGE=it

# Shared password gate. Empty = no gate (local dev). On Vercel set a STRONG value so
# only people who know it can start a session (protects your HeyGen credits).
APP_PASSWORD=

# Tavus
TAVUS_API_KEY=
TAVUS_PERSONA_ID=p8a490c4dfd4
TAVUS_REPLICA_ID=rf4e9d9790f0