---
import {
  getCandidateByCode,
  getProgress,
  getSession,
  getUtterances,
  getIntegrityEvents,
  computeIntegritySummary,
  getSnapshots,
  type SessionRow,
} from '../../lib/db';
import { questions } from '../../lib/prompt';
import { rates } from '../../lib/pricing';
import { INTEGRITY_LABELS, type IntegrityType } from '../../lib/proctor-config';
import { t, formatDateTime, formatTime, type I18nKey } from '../../lib/i18n';

export const prerender = false;

const code = (Astro.params.code ?? '').toUpperCase();
const candidate = getCandidateByCode(code);

if (!candidate) {
  return Astro.redirect('/admin');
}

const progress = getProgress(candidate.id);

function calcCost(session: SessionRow | null, durationMin: number) {
  if (!session?.ended_at) return { usd: 0, credits: null };
  if (session.provider === 'heygen') {
    const credits = durationMin * rates.heygenCreditsPerMin;
    return { usd: credits * rates.heygenUsdPerCredit, credits: Math.round(credits * 10) / 10 };
  }
  return { usd: Math.max(0.5, Math.ceil(durationMin * 600) / 600) * rates.tavusUsdPerMin, credits: null };
}

type TavusMeta = {
  provider: 'tavus';
  fetched_at: string;
  conversation_id: string;
  status?: string;
  shutdown_reason?: string;
  perception_analysis?: string | null;
  tavus_transcript?: Array<{
    role: string;
    content: string;
    seconds_from_start: number;
    duration: number;
  }> | null;
  recording?: { storage_uri?: string; duration?: number } | null;
};
type HeyGenMeta = {
  provider: 'heygen';
  fetched_at: string;
  session_id: string;
  duration_sec?: number | null;
  credits_consumed?: number | null;
  end_reason?: string | null;
  mode?: string | null;
  source?: string | null;
};
type ProviderMeta = TavusMeta | HeyGenMeta | null;

function parseProviderMeta(raw: string | null): ProviderMeta {
  if (!raw) return null;
  try {
    return JSON.parse(raw) as ProviderMeta;
  } catch {
    return null;
  }
}

const questionDetails = progress.map((p) => {
  const session = p.session_id ? (getSession(p.session_id) ?? null) : null;
  const utterances = session ? getUtterances(session.id) : [];
  const integrityEvents = session ? getIntegrityEvents(session.id) : [];
  const integrity = session ? computeIntegritySummary(session.id) : null;
  const snapshots = session ? getSnapshots(session.id) : [];
  const question = questions.questions[p.question_index] ?? null;
  const durationMin = session?.ended_at
    ? (new Date(session.ended_at).getTime() - new Date(session.started_at).getTime()) / 60_000
    : 0;
  const cost = calcCost(session, durationMin);
  const providerMeta = parseProviderMeta(session?.provider_meta ?? null);
  return { p, session, utterances, integrityEvents, integrity, snapshots, question, durationMin, cost, providerMeta };
});

const totalCostUsd = questionDetails.reduce((s, d) => s + d.cost.usd, 0);
const totalDurationMin = questionDetails.reduce((s, d) => s + d.durationMin, 0);
const totalIntegrityEvents = questionDetails.reduce(
  (s, d) => s + (d.integrityEvents?.length ?? 0),
  0,
);

function fmtMeta(type: string, metaJson: string | null): string {
  if (!metaJson) return '';
  let meta: Record<string, unknown> = {};
  try { meta = JSON.parse(metaJson) as Record<string, unknown>; } catch { return ''; }
  const parts: string[] = [];
  if (typeof meta.durationMs === 'number') parts.push(`${(meta.durationMs / 1000).toFixed(1)}s`);
  if (type === 'multiple_faces' && typeof meta.count === 'number') parts.push(`${meta.count} volti`);
  if (type === 'looking_away' && typeof meta.yaw === 'number') parts.push(`yaw ${meta.yaw}°`);
  if (type === 'looking_down' && typeof meta.pitch === 'number') parts.push(`pitch ${meta.pitch}°`);
  return parts.join(' · ');
}
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Intervista — {candidate.display_name ?? code}</title>
  </head>
  <body>
    <main>
      <!-- ── CANDIDATE HEADER ─────────────────────────────────────────────────── -->
      <header class="cand-header">
        <div class="cand-nav">
          <a href="/admin" class="back">{t('nav.back_archive')}</a>
        </div>
        <div class="cand-info">
          <h1>{candidate.display_name ?? t('admin.detail.unnamed')}</h1>
          <span class="resume-code">{candidate.resume_code}</span>
        </div>
        <div class="cand-stats">
          <div class="stat">
            <span class="stat-label">{t('admin.detail.stat.questions')}</span>
            <span class="stat-val">{progress.filter((p) => p.status === 'completed').length}/{progress.length}</span>
          </div>
          <div class="stat">
            <span class="stat-label">{t('admin.detail.stat.total_duration')}</span>
            <span class="stat-val">{totalDurationMin.toFixed(1)} {t('session.min')}</span>
          </div>
          <div class="stat">
            <span class="stat-label">{t('admin.detail.stat.total_cost')}</span>
            <span class="stat-val cost">${totalCostUsd.toFixed(2)}</span>
          </div>
          <div class="stat">
            <span class="stat-label">{t('admin.detail.stat.integrity')}</span>
            <span class="stat-val">{totalIntegrityEvents}</span>
          </div>
          <div class="stat">
            <span class="stat-label">{t('admin.detail.stat.registered')}</span>
            <span class="stat-val">{formatDateTime(candidate.created_at)}</span>
          </div>
        </div>
      </header>

      <!-- ── PER-QUESTION SECTIONS ───────────────────────────────────────────── -->
      {questionDetails.map(({ p, session, utterances, integrityEvents, integrity, snapshots, question, durationMin, cost, providerMeta }) => {
        const tz = session?.timezone ?? null;
        const tavusMeta = providerMeta?.provider === 'tavus' ? providerMeta : null;
        const heygenMeta = providerMeta?.provider === 'heygen' ? providerMeta : null;
        const heygenActualCredits = heygenMeta?.credits_consumed ?? null;
        const heygenActualDurationMin = heygenMeta?.duration_sec != null ? heygenMeta.duration_sec / 60 : null;
        const heygenActualCostUsd = heygenActualCredits != null ? heygenActualCredits * rates.heygenUsdPerCredit : null;
        return (
        <section class="q-section">
          <!-- Question header -->
          <div class="q-head">
            <div class="q-title">
              <span class="q-num">D{p.question_index + 1}</span>
              <span class="q-text">{question?.text ?? `Domanda ${p.question_index + 1}`}</span>
            </div>
            <span class={`status-badge status-${p.status}`}>
              {t(`status.${p.status}` as I18nKey)}
            </span>
          </div>

          {/* Session meta */}
          {session && (
            <div class="session-meta">
              <span class="badge-provider">{session.provider}</span>
              {session.question_id && <span class="meta-chip">ID: {session.question_id}</span>}
              <span class="meta-chip">{t('session.id_prefix')}{session.id}</span>
              <span class="meta-chip">{t('session.started')} {formatDateTime(session.started_at, tz)}</span>
              {session.ended_at && <span class="meta-chip">{t('session.ended')} {formatTime(session.ended_at, tz)}</span>}
              {session.ended_at && (
                <span class="meta-chip cost">
                  {heygenActualDurationMin != null
                    ? `${heygenActualDurationMin.toFixed(1)} ${t('session.min')} (${t('session.actual_duration')})`
                    : `${durationMin.toFixed(1)} ${t('session.min')}`}
                  {' · '}
                  {heygenActualCostUsd != null
                    ? `$${heygenActualCostUsd.toFixed(2)} (${heygenActualCredits} ${t('session.credits')})`
                    : `$${cost.usd.toFixed(2)} (${t('session.estimated')})`}
                </span>
              )}
              {(tavusMeta?.shutdown_reason ?? session.ended_reason) && (
                <span class="meta-chip reason">{tavusMeta?.shutdown_reason ?? session.ended_reason}</span>
              )}
              {session.provider_session_id && (
                <button
                  class="btn-refresh"
                  data-session-id={String(session.id)}
                  data-loading-text={t('provider.loading')}
                >
                  {providerMeta ? t('provider.refresh') : t('provider.load')}
                </button>
              )}
            </div>
          )}
          {!session && p.status === 'pending' && (
            <p class="no-session">{t('session.no_session')}</p>
          )}

          {/* ── Provider AI data (Tavus / HeyGen actual) ── */}
          {tavusMeta && (
            <div class="provider-block">
              <div class="provider-head">
                <span class="provider-title">{t('provider.tavus.title')}</span>
                {tavusMeta.fetched_at && (
                  <span class="provider-fetched">{t('provider.updated')} {formatTime(tavusMeta.fetched_at, tz)}</span>
                )}
              </div>

              {/* Perception analysis — AI visual report */}
              {tavusMeta.perception_analysis && (
                <div class="perception">
                  <span class="perception-label">{t('provider.tavus.perception_label')}</span>
                  <div class="perception-text">
                    {tavusMeta.perception_analysis.split('\n\n').map((para) => (
                      <p>{para}</p>
                    ))}
                  </div>
                </div>
              )}

              {/* Recording link */}
              {tavusMeta.recording?.storage_uri && (
                <div class="recording-row">
                  <span class="recording-label">{t('provider.tavus.recording')}</span>
                  <code class="recording-uri">{tavusMeta.recording.storage_uri}</code>
                  {tavusMeta.recording.duration && (
                    <span class="recording-dur">
                      {(tavusMeta.recording.duration / 60_000).toFixed(1)} {t('session.min')}
                    </span>
                  )}
                </div>
              )}

              {/* Tavus detailed transcript (with timing) */}
              {tavusMeta.tavus_transcript && tavusMeta.tavus_transcript.length > 0 && (
                <details class="tavus-transcript">
                  <summary>{t('provider.tavus.transcript')} ({tavusMeta.tavus_transcript.length} {t('transcript.turns')})</summary>
                  <ol class="t-transcript">
                    {tavusMeta.tavus_transcript.map((turn) => (
                      <li class={`t-turn t-${turn.role}`}>
                        <span class="t-who">
                          {turn.role === 'assistant' ? t('speaker.avatar') : turn.role === 'user' ? t('speaker.candidate') : turn.role}
                          <span class="t-timing">
                            +{turn.seconds_from_start.toFixed(1)}s
                            {turn.duration > 0 && ` · ${turn.duration.toFixed(1)}s`}
                          </span>
                        </span>
                        <span class="t-text">{turn.content}</span>
                      </li>
                    ))}
                  </ol>
                </details>
              )}
            </div>
          )}

          {heygenMeta && (heygenMeta.credits_consumed != null || heygenMeta.end_reason) && (
            <div class="provider-block">
              <div class="provider-head">
                <span class="provider-title">{t('provider.heygen.title')}</span>
                {heygenMeta.fetched_at && (
                  <span class="provider-fetched">{t('provider.updated')} {formatTime(heygenMeta.fetched_at, tz)}</span>
                )}
              </div>
              <div class="heygen-stats">
                {heygenMeta.credits_consumed != null && (
                  <div class="hg-stat">
                    <span class="hg-label">{t('provider.heygen.credits')}</span>
                    <span class="hg-val">{heygenMeta.credits_consumed}</span>
                  </div>
                )}
                {heygenMeta.duration_sec != null && (
                  <div class="hg-stat">
                    <span class="hg-label">{t('provider.heygen.duration')}</span>
                    <span class="hg-val">{(heygenMeta.duration_sec / 60).toFixed(1)} {t('session.min')}</span>
                  </div>
                )}
                {heygenActualCostUsd != null && (
                  <div class="hg-stat">
                    <span class="hg-label">{t('provider.heygen.cost')}</span>
                    <span class="hg-val cost">${heygenActualCostUsd.toFixed(2)}</span>
                  </div>
                )}
                {heygenMeta.end_reason && (
                  <div class="hg-stat">
                    <span class="hg-label">{t('provider.heygen.end_reason')}</span>
                    <span class="hg-val">{heygenMeta.end_reason}</span>
                  </div>
                )}
                {heygenMeta.mode && (
                  <div class="hg-stat">
                    <span class="hg-label">{t('provider.heygen.mode')}</span>
                    <span class="hg-val">{heygenMeta.mode}</span>
                  </div>
                )}
              </div>
            </div>
          )}

          {session && !providerMeta && session.provider_session_id && (
            <p class="no-provider-data">
              {t('provider.no_data')}
              {' '}
              {t('provider.no_data_hint')}
            </p>
          )}

          {/* Integrity */}
          {integrity && integrity.total > 0 && (
            <div class="integrity-block">
              <div class="integrity-head">
                <span class="int-title">{t('integrity.title')}</span>
                <span class={`band band-${integrity.band}`}>
                  {t('integrity.risk')} {t(`integrity.band.${integrity.band}` as I18nKey)} · {integrity.score}
                </span>
              </div>
              <ol class="events">
                {integrityEvents.map((e) => (
                  <li class="event">
                    <span class="ev-label">{INTEGRITY_LABELS[e.type as IntegrityType] ?? e.type}</span>
                    <span class="ev-detail">{fmtMeta(e.type, e.meta)}</span>
                    <span class="ev-time">{formatTime(e.ts, tz)}</span>
                  </li>
                ))}
              </ol>
            </div>
          )}
          {integrity && integrity.total === 0 && session && (
            <p class="int-clean">{t('integrity.clean')}</p>
          )}

          {/* Answer summary */}
          {p.answer_summary && (
            <div class="answer-summary">
              <span class="as-label">{t('answer.summary.title')}</span>
              <p class="as-text">{p.answer_summary}</p>
            </div>
          )}

          {/* Snapshots */}
          {snapshots.length > 0 && (
            <div class="snapshots">
              <p class="snap-label">
                {t('snapshots.title')} ({snapshots.length})
                <span class="snap-legend">
                  <span class="snap-dot snap-dot-event"></span>{t('snapshots.legend.event')}
                  <span class="snap-dot snap-dot-periodic"></span>{t('snapshots.legend.periodic')}
                </span>
              </p>
              <div class="snap-grid">
                {snapshots.map((s) => (
                  <div class={`snap-item ${s.trigger ? 'snap-triggered' : 'snap-periodic'}`}>
                    <div class="snap-img-wrap">
                      <img
                        src={`/api/snapshot/${s.path.replace(/^snapshots\//, '')}`}
                        alt={`Snapshot ${formatTime(s.ts, tz)}${s.trigger ? ` [${s.trigger}]` : ''}`}
                        class="snap-img"
                        loading="lazy"
                      />
                      {s.trigger && (
                        <span class={`snap-event-badge snap-event-${s.trigger.replace(/_/g, '-')}`}>
                          {INTEGRITY_LABELS[s.trigger as IntegrityType] ?? s.trigger}
                        </span>
                      )}
                    </div>
                    <span class="snap-time">{formatTime(s.ts, tz)}</span>
                  </div>
                ))}
              </div>
            </div>
          )}

          {/* Transcript */}
          {utterances.length > 0 && (
            <div class="transcript-block">
              <p class="transcript-label">{t('transcript.title')} ({utterances.length} {t('transcript.turns')})</p>
              <ol class="transcript">
                {utterances.map((u) => (
                  <li class={`turn ${u.role}`}>
                    <span class="who">
                      {u.role === 'avatar' ? t('speaker.avatar') : t('speaker.candidate')}
                      <span class="turn-time">{formatTime(u.created_at, tz)}</span>
                    </span>
                    <span class="text">{u.text}</span>
                  </li>
                ))}
              </ol>
            </div>
          )}
          {session && utterances.length === 0 && (
            <p class="no-session">{t('transcript.empty')}</p>
          )}
        </section>
        );
      })}
    </main>

    <style>
      :global(body) {
        margin: 0;
        background: #0b0c10;
        color: #e8eaed;
        font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
      }
      main {
        max-width: 840px;
        margin: 0 auto;
        padding: 32px 20px 80px;
      }

      /* ── Candidate header ── */
      .cand-header {
        margin-bottom: 36px;
      }
      .cand-nav { margin-bottom: 12px; }
      .back {
        color: #6b7280;
        font-size: 0.85rem;
        text-decoration: none;
      }
      .back:hover { color: #9aa0aa; }
      .cand-info {
        display: flex;
        align-items: baseline;
        gap: 14px;
        margin-bottom: 16px;
      }
      h1 { margin: 0; font-size: 1.6rem; }
      .resume-code {
        font-family: monospace;
        font-size: 1rem;
        color: #a7f3d0;
        letter-spacing: 0.08em;
        background: #0d2a1c;
        padding: 2px 10px;
        border-radius: 6px;
      }
      .cand-stats {
        display: flex;
        flex-wrap: wrap;
        gap: 16px;
      }
      .stat {
        display: flex;
        flex-direction: column;
        gap: 2px;
        padding: 10px 16px;
        background: #101119;
        border: 1px solid #2a2c36;
        border-radius: 10px;
        min-width: 100px;
      }
      .stat-label {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: #6b7280;
      }
      .stat-val {
        font-size: 1rem;
        font-weight: 700;
        font-variant-numeric: tabular-nums;
      }
      .stat-val.cost { color: #a7f3d0; }

      /* ── Per-question sections ── */
      .q-section {
        margin-bottom: 32px;
        border: 1px solid #2a2c36;
        border-radius: 14px;
        overflow: hidden;
      }
      .q-head {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
        padding: 16px 20px 12px;
        background: #101119;
        border-bottom: 1px solid #1c1e27;
      }
      .q-title {
        display: flex;
        align-items: baseline;
        gap: 12px;
      }
      .q-num {
        font-size: 0.75rem;
        font-weight: 700;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        flex-shrink: 0;
      }
      .q-text {
        font-size: 0.95rem;
        font-weight: 600;
        line-height: 1.4;
        color: #cbd5e1;
      }
      .status-badge {
        flex-shrink: 0;
        padding: 3px 12px;
        border-radius: 999px;
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.04em;
      }
      .status-completed { background: #10b981; color: #04150f; }
      .status-pending   { background: #374151; color: #9aa0aa; }
      .status-timeout   { background: #fbbf24; color: #1a1400; }
      .status-skipped   { background: #4b5563; color: #d1d5db; }

      /* Session meta */
      .session-meta {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 8px;
        padding: 10px 20px;
        background: #0e0f16;
        border-bottom: 1px solid #1c1e27;
        font-size: 0.82rem;
      }
      .badge-provider {
        padding: 2px 10px;
        border-radius: 999px;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        background: #10b981;
        color: #04150f;
      }
      .meta-chip {
        color: #9aa0aa;
      }
      .meta-chip.cost { color: #a7f3d0; font-weight: 600; }
      .meta-chip.reason {
        padding: 1px 8px;
        border-radius: 6px;
        background: #2a2c36;
        color: #cbd5e1;
      }
      .no-session { padding: 12px 20px; color: #6b7280; font-size: 0.85rem; margin: 0; }
      .int-clean  { padding: 10px 20px; color: #10b981; font-size: 0.83rem; margin: 0; }

      /* Integrity */
      .integrity-block {
        padding: 14px 20px;
        border-bottom: 1px solid #1c1e27;
        background: #0b0c10;
      }
      .integrity-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 10px;
      }
      .int-title {
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #6b7280;
        font-weight: 600;
      }
      .band {
        padding: 2px 10px;
        font-size: 0.7rem;
        font-weight: 700;
        border-radius: 999px;
        text-transform: uppercase;
      }
      .band-low    { color: #04150f; background: #10b981; }
      .band-medium { color: #1a1400; background: #fbbf24; }
      .band-high   { color: #fff;    background: #ef4444; }
      .events {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 5px;
      }
      .event {
        display: grid;
        grid-template-columns: 1fr auto auto;
        align-items: baseline;
        gap: 10px;
        padding: 5px 10px;
        border-radius: 7px;
        background: #17181f;
        font-size: 0.82rem;
      }
      .ev-label  { font-weight: 600; }
      .ev-detail { color: #9aa0aa; font-variant-numeric: tabular-nums; }
      .ev-time   { color: #6b7280; font-size: 0.76rem; font-variant-numeric: tabular-nums; }

      /* Answer summary */
      .answer-summary {
        padding: 14px 20px;
        border-bottom: 1px solid #1c1e27;
        background: #0e1620;
      }
      .as-label {
        display: block;
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #4ea1ff;
        font-weight: 600;
        margin-bottom: 6px;
      }
      .as-text {
        margin: 0;
        font-size: 0.9rem;
        line-height: 1.5;
        color: #cbd5e1;
      }

      /* Snapshots */
      .snapshots {
        padding: 14px 20px;
        border-bottom: 1px solid #1c1e27;
      }
      .snap-label {
        display: flex;
        align-items: center;
        gap: 12px;
        margin: 0 0 10px;
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #6b7280;
        font-weight: 600;
      }
      .snap-legend {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 0.7rem;
        letter-spacing: 0;
        text-transform: none;
        color: #4b5563;
        font-weight: 400;
      }
      .snap-dot {
        display: inline-block;
        width: 8px;
        height: 8px;
        border-radius: 50%;
      }
      .snap-dot-event    { background: #ef4444; }
      .snap-dot-periodic { background: #374151; }
      .snap-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
      }
      .snap-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
      }
      .snap-img-wrap {
        position: relative;
        display: inline-block;
      }
      .snap-img {
        width: 160px;
        height: 90px;
        object-fit: cover;
        border-radius: 8px;
        background: #1c1e27;
        border: 1px solid #2a2c36;
        display: block;
      }
      .snap-triggered .snap-img {
        border-color: #7f1d1d;
        box-shadow: 0 0 0 2px #ef444440;
      }
      .snap-event-badge {
        position: absolute;
        bottom: 4px;
        left: 4px;
        right: 4px;
        padding: 2px 6px;
        border-radius: 4px;
        font-size: 0.62rem;
        font-weight: 700;
        text-align: center;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        background: rgba(239, 68, 68, 0.85);
        color: #fff;
        backdrop-filter: blur(2px);
      }
      .snap-time {
        font-size: 0.72rem;
        color: #6b7280;
        font-variant-numeric: tabular-nums;
      }
      .snap-triggered .snap-time { color: #f87171; }

      /* Transcript */
      .transcript-block {
        padding: 14px 20px;
      }
      .transcript-label {
        margin: 0 0 10px;
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #6b7280;
        font-weight: 600;
      }
      .transcript {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 8px;
      }
      .turn {
        display: flex;
        flex-direction: column;
        gap: 3px;
        padding: 10px 14px;
        border-radius: 10px;
        background: #17181f;
        border: 1px solid #2a2c36;
      }
      .turn.avatar { border-left: 3px solid #10b981; }
      .turn.user   { border-left: 3px solid #4ea1ff; }
      .who {
        display: flex;
        align-items: baseline;
        gap: 8px;
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: #9aa0aa;
      }
      .turn-time {
        font-size: 0.68rem;
        color: #4b5563;
        font-variant-numeric: tabular-nums;
      }
      .text { font-size: 0.9rem; line-height: 1.45; }

      /* ── Refresh button ── */
      .btn-refresh {
        padding: 2px 10px;
        font-size: 0.76rem;
        font-weight: 600;
        background: transparent;
        border: 1px solid #374151;
        border-radius: 6px;
        color: #9aa0aa;
        cursor: pointer;
        transition: border-color 0.15s, color 0.15s;
      }
      .btn-refresh:hover { border-color: #10b981; color: #10b981; }
      .btn-refresh:disabled { opacity: 0.5; cursor: default; }

      /* ── Provider data block ── */
      .provider-block {
        padding: 14px 20px;
        border-bottom: 1px solid #1c1e27;
        background: #060b18;
      }
      .provider-head {
        display: flex;
        align-items: baseline;
        gap: 12px;
        margin-bottom: 12px;
      }
      .provider-title {
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #818cf8;
        font-weight: 700;
      }
      .provider-fetched {
        font-size: 0.72rem;
        color: #4b5563;
      }
      .no-provider-data {
        padding: 10px 20px;
        margin: 0;
        font-size: 0.82rem;
        color: #4b5563;
        border-bottom: 1px solid #1c1e27;
      }

      /* Perception analysis */
      .perception {
        margin-bottom: 14px;
      }
      .perception-label {
        display: block;
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: #818cf8;
        font-weight: 600;
        margin-bottom: 8px;
      }
      .perception-text {
        background: #0d1124;
        border: 1px solid #1e2248;
        border-radius: 10px;
        padding: 14px 16px;
      }
      .perception-text p {
        margin: 0 0 10px;
        font-size: 0.88rem;
        line-height: 1.6;
        color: #c7d2fe;
      }
      .perception-text p:last-child { margin-bottom: 0; }

      /* Recording row */
      .recording-row {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 8px 12px;
        background: #17181f;
        border-radius: 8px;
        margin-bottom: 12px;
      }
      .recording-label {
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: #6b7280;
        font-weight: 600;
        flex-shrink: 0;
      }
      .recording-uri {
        font-size: 0.8rem;
        color: #a7f3d0;
        word-break: break-all;
        flex: 1;
      }
      .recording-dur { color: #6b7280; font-size: 0.8rem; flex-shrink: 0; }

      /* Tavus detailed transcript */
      .tavus-transcript {
        margin-top: 10px;
      }
      .tavus-transcript summary {
        cursor: pointer;
        font-size: 0.78rem;
        color: #6b7280;
        padding: 6px 0;
        user-select: none;
      }
      .tavus-transcript summary:hover { color: #9aa0aa; }
      .t-transcript {
        list-style: none;
        margin: 8px 0 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 6px;
      }
      .t-turn {
        display: flex;
        flex-direction: column;
        gap: 2px;
        padding: 8px 12px;
        border-radius: 8px;
        background: #17181f;
        border: 1px solid #2a2c36;
      }
      .t-turn.t-assistant { border-left: 3px solid #818cf8; }
      .t-turn.t-user      { border-left: 3px solid #4ea1ff; }
      .t-turn.t-system    { border-left: 3px solid #374151; opacity: 0.6; }
      .t-who {
        display: flex;
        align-items: baseline;
        gap: 8px;
        font-size: 0.68rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: #9aa0aa;
      }
      .t-timing {
        font-size: 0.66rem;
        color: #4b5563;
        font-variant-numeric: tabular-nums;
      }
      .t-text { font-size: 0.85rem; line-height: 1.4; }

      /* HeyGen actual stats */
      .heygen-stats {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
      }
      .hg-stat {
        display: flex;
        flex-direction: column;
        gap: 2px;
        padding: 8px 14px;
        background: #0d0e17;
        border: 1px solid #1e2248;
        border-radius: 8px;
        min-width: 90px;
      }
      .hg-label {
        font-size: 0.68rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: #6b7280;
      }
      .hg-val {
        font-size: 0.9rem;
        font-weight: 700;
        font-variant-numeric: tabular-nums;
      }
      .hg-val.cost { color: #a7f3d0; }
    </style>

    <script>
      document.addEventListener('click', (e) => {
        const btn = (e.target as Element).closest<HTMLButtonElement>('.btn-refresh');
        if (!btn) return;
        const sessionId = btn.dataset.sessionId;
        if (!sessionId) return;
        btn.disabled = true;
        const original = btn.textContent ?? '';
        btn.textContent = btn.dataset.loadingText ?? '…';
        fetch('/api/interview/provider-refresh', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ sessionId: Number(sessionId) }),
        })
          .then((r) => r.json())
          .then((d) => {
            if ((d as { ok?: boolean }).ok) {
              location.reload();
            } else {
              btn.disabled = false;
              btn.textContent = original;
            }
          })
          .catch(() => {
            btn.disabled = false;
            btn.textContent = original;
          });
      });
    </script>
  </body>
</html>
