---
// Questions CRUD. Lists the question bank with an enabled badge, and supports
// create/edit, an enable/disable toggle, and delete. The API blocks deleting an
// enabled question (409) — that error message is surfaced to the operator.
// Talks to /api/admin/questions and /api/admin/questions/[id]. Vanilla fetch.
import AdminLayout from '../../layouts/AdminLayout.astro';
import { resolveLocale, t, LOCALE_COOKIE, type Locale } from '../../lib/i18n';

export const prerender = false;

const locale: Locale = resolveLocale(
  Astro.cookies.get(LOCALE_COOKIE)?.value,
  Astro.request.headers.get('accept-language'),
);
---

<AdminLayout section="questions" title={t(locale, 'admin.nav.questions')}>
  <div class="mb-8 flex items-end justify-between gap-4">
    <div>
      <h1 class="text-2xl font-semibold tracking-tight">{t(locale, 'admin.nav.questions')}</h1>
      <p class="mt-1 text-sm text-muted">{t(locale, 'admin.hub.questions.desc')}</p>
    </div>
    <button type="button" id="btn-new" class="btn btn-primary shrink-0">
      {t(locale, 'admin.questions.new')}
    </button>
  </div>

  <p id="status" class="mb-5 hidden rounded-md px-4 py-2.5 text-sm" role="status"></p>

  <section class="card overflow-hidden">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-border text-left text-xs uppercase tracking-wide text-faint">
          <th class="px-5 py-3 font-medium">{t(locale, 'admin.questions.col.name')}</th>
          <th class="px-5 py-3 font-medium">{t(locale, 'admin.questions.col.status')}</th>
          <th class="px-5 py-3 font-medium">{t(locale, 'admin.questions.col.objective')}</th>
          <th class="px-5 py-3"></th>
        </tr>
      </thead>
      <tbody id="rows">
        <tr><td colspan="4" class="px-5 py-6 text-muted">{t(locale, 'action.loading')}</td></tr>
      </tbody>
    </table>
  </section>
  <p class="hint">{t(locale, 'admin.questions.delete_hint')}</p>

  <section id="editor" class="card mt-8 p-6" hidden>
    <h2 id="editor-title" class="mb-5 text-lg font-semibold">{t(locale, 'admin.questions.editor.new')}</h2>
    <form id="form">
      <input type="hidden" id="f-id" />
      <input type="hidden" id="f-enabled" />
      <div class="field">
        <label class="label" for="f-name">{t(locale, 'admin.questions.field.name')} <span class="text-danger">*</span></label>
        <input type="text" id="f-name" class="input" required />
      </div>
      <div class="field">
        <label class="label" for="f-text">{t(locale, 'admin.questions.field.text')} <span class="text-danger">*</span></label>
        <textarea id="f-text" class="input" rows="5" required></textarea>
        <p class="hint">{t(locale, 'admin.questions.field.text.hint')}</p>
      </div>
      <div class="field">
        <label class="label" for="f-objective">{t(locale, 'admin.questions.field.objective')}</label>
        <textarea id="f-objective" class="input min-h-20" rows="3"></textarea>
        <p class="hint">{t(locale, 'admin.questions.field.objective.hint')}</p>
      </div>
      <div class="flex gap-3 pt-1">
        <button type="submit" class="btn btn-primary">{t(locale, 'action.save')}</button>
        <button type="button" id="btn-cancel" class="btn btn-ghost">{t(locale, 'action.cancel')}</button>
      </div>
    </form>
  </section>

  <script>
    import { t, type Locale } from '../../lib/i18n';
    import { confirmDialog } from '../../scripts/modal';

    const locale = (document.documentElement.lang || 'it') as Locale;
    const API = '/api/admin/questions';
    const $ = (id: string) => document.getElementById(id) as HTMLElement;
    const statusEl = $('status');

    function flash(msg: string, ok = true) {
      statusEl.hidden = false;
      statusEl.textContent = msg;
      statusEl.className =
        'mb-5 rounded-md px-4 py-2.5 text-sm ' +
        (ok ? 'bg-success-soft text-success' : 'bg-danger-soft text-danger');
    }
    function clearFlash() {
      statusEl.hidden = true;
    }

    async function api(url: string, opts?: RequestInit) {
      // Always tag requests as JSON. Same-origin this is a no-op, but it exempts our
      // bodyless mutations (DELETE, duplicate POST) from Astro's checkOrigin CSRF guard,
      // which otherwise 403s them behind a reverse proxy where Origin ≠ internal host.
      const res = await fetch(url, {
        ...opts,
        headers: { 'Content-Type': 'application/json', ...(opts?.headers as Record<string, string> | undefined) },
      });
      let data: any = null;
      try {
        data = await res.json();
      } catch {
        /* 204 */
      }
      if (!res.ok) throw new Error((data && data.error) || 'HTTP ' + res.status);
      return data;
    }

    function preview(s: string | null): string {
      if (!s) return '—';
      const clean = s.trim().replace(/\s+/g, ' ');
      return clean.length > 80 ? clean.slice(0, 80) + '…' : clean;
    }

    async function loadList() {
      const rows = $('rows');
      try {
        const list = await api(API);
        if (!list.length) {
          rows.innerHTML =
            '<tr><td colspan="4" class="px-5 py-10 text-center"><span class="block font-medium text-fg">' +
            t(locale, 'admin.questions.empty.title') +
            '</span><span class="mt-1 block text-sm text-muted">' +
            t(locale, 'admin.questions.empty.hint') +
            '</span></td></tr>';
          return;
        }
        rows.innerHTML = '';
        for (const q of list) {
          const on = q.enabled === 1 || q.enabled === true;
          const tr = document.createElement('tr');
          tr.className = 'border-b border-border last:border-0 hover:bg-panel';

          const name = document.createElement('td');
          name.className = 'px-5 py-3 font-medium text-fg';
          name.textContent = q.name;

          const st = document.createElement('td');
          st.className = 'px-5 py-3';
          const badge = document.createElement('span');
          badge.className = 'badge ' + (on ? 'badge-on' : 'badge-off');
          badge.textContent = on ? t(locale, 'state.enabled') : t(locale, 'state.disabled');
          st.appendChild(badge);

          const obj = document.createElement('td');
          obj.className = 'px-5 py-3 text-muted';
          obj.textContent = preview(q.objective);

          const act = document.createElement('td');
          act.className = 'px-5 py-3 text-right whitespace-nowrap';
          const toggle = document.createElement('button');
          toggle.className = 'btn btn-ghost btn-sm';
          toggle.textContent = on
            ? t(locale, 'admin.questions.action.disable')
            : t(locale, 'admin.questions.action.enable');
          toggle.onclick = () => setEnabled(q, !on);
          const edit = document.createElement('button');
          edit.className = 'btn btn-ghost btn-sm ml-1.5';
          edit.textContent = t(locale, 'action.edit');
          edit.onclick = () => openEdit(q.id);
          const dup = document.createElement('button');
          dup.className = 'btn btn-ghost btn-sm ml-1.5';
          dup.textContent = t(locale, 'action.duplicate');
          dup.onclick = () => duplicate(q.id);
          act.append(toggle, edit, dup);
          // Enabled questions cannot be deleted (API guards with a 409) — so the Delete
          // button only appears once a question is disabled.
          if (!on) {
            const del = document.createElement('button');
            del.className = 'btn btn-danger btn-sm ml-1.5';
            del.textContent = t(locale, 'action.delete');
            del.onclick = () => remove(q.id, q.name);
            act.append(del);
          }

          tr.append(name, st, obj, act);
          rows.appendChild(tr);
        }
      } catch (e: any) {
        rows.innerHTML = '<tr><td colspan="4" class="px-5 py-6 text-danger">' + e.message + '</td></tr>';
      }
    }

    // Toggle. The PUT endpoint requires name+text, so we send the full row plus the
    // new enabled flag rather than a bare { enabled } patch.
    async function setEnabled(q: any, enabled: boolean) {
      clearFlash();
      try {
        await api(API + '/' + q.id, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name: q.name,
            text: q.text,
            objective: q.objective ?? null,
            enabled,
          }),
        });
        flash(enabled ? t(locale, 'admin.questions.msg.enabled') : t(locale, 'admin.questions.msg.disabled'));
        loadList();
      } catch (e: any) {
        flash(e.message, false);
      }
    }

    function openNew() {
      clearFlash();
      $('editor-title').textContent = t(locale, 'admin.questions.editor.new');
      ($('f-id') as HTMLInputElement).value = '';
      ($('f-enabled') as HTMLInputElement).value = '';
      ($('form') as HTMLFormElement).reset();
      $('editor').hidden = false;
      ($('f-name') as HTMLInputElement).focus();
    }

    async function openEdit(id: number) {
      clearFlash();
      try {
        const q = await api(API + '/' + id);
        $('editor-title').textContent = t(locale, 'admin.questions.editor.edit', { id: q.id });
        ($('f-id') as HTMLInputElement).value = String(q.id);
        ($('f-enabled') as HTMLInputElement).value = q.enabled === 1 || q.enabled === true ? '1' : '0';
        ($('f-name') as HTMLInputElement).value = q.name || '';
        ($('f-text') as HTMLTextAreaElement).value = q.text || '';
        ($('f-objective') as HTMLTextAreaElement).value = q.objective || '';
        $('editor').hidden = false;
        window.scrollTo({ top: document.body.scrollHeight, behavior: 'smooth' });
      } catch (e: any) {
        flash(e.message, false);
      }
    }

    async function duplicate(id: number) {
      clearFlash();
      try {
        await api(API + '/' + id + '/duplicate', { method: 'POST' });
        flash(t(locale, 'action.duplicated'));
        loadList();
      } catch (e: any) {
        flash(e.message, false);
      }
    }

    async function remove(id: number, name: string) {
      const ok = await confirmDialog({
        title: t(locale, 'action.confirm_title'),
        message: t(locale, 'admin.questions.confirm_delete', { name }),
        confirmLabel: t(locale, 'action.delete'),
        cancelLabel: t(locale, 'action.cancel'),
        tone: 'danger',
      });
      if (!ok) return;
      try {
        await api(API + '/' + id, { method: 'DELETE' });
        flash(t(locale, 'admin.questions.msg.deleted'));
        loadList();
      } catch (e: any) {
        // 409 when the question is still enabled — surface the API message verbatim.
        flash(e.message, false);
      }
    }

    ($('form') as HTMLFormElement).addEventListener('submit', async (ev) => {
      ev.preventDefault();
      const id = ($('f-id') as HTMLInputElement).value;
      const payload: any = {
        name: ($('f-name') as HTMLInputElement).value.trim(),
        text: ($('f-text') as HTMLTextAreaElement).value,
        objective: ($('f-objective') as HTMLTextAreaElement).value.trim() || null,
      };
      // Preserve the existing enabled state on edit; new questions default enabled.
      if (id) payload.enabled = ($('f-enabled') as HTMLInputElement).value === '1';
      try {
        if (id) {
          await api(API + '/' + id, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          flash(t(locale, 'admin.questions.msg.saved'));
        } else {
          await api(API, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          flash(t(locale, 'admin.questions.msg.created'));
        }
        $('editor').hidden = true;
        loadList();
      } catch (e: any) {
        flash(e.message, false);
      }
    });

    ($('btn-new') as HTMLButtonElement).onclick = openNew;
    ($('btn-cancel') as HTMLButtonElement).onclick = () => {
      $('editor').hidden = true;
      clearFlash();
    };

    loadList();
  </script>
</AdminLayout>
