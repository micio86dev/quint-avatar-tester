---
// Templates CRUD. A template is the full experiment recipe: meta (name/description/
// enabled) + an ordered selection of enabled questions + two provider-config blobs
// (HeyGen / Tavus). The editor has three parts; membership is saved via the dedicated
// /questions membership endpoint, meta+config via the template PUT. Vanilla fetch.
import AdminLayout from '../../layouts/AdminLayout.astro';
import { resolveLocale, t, LOCALE_COOKIE, type Locale } from '../../lib/i18n';

export const prerender = false;

const locale: Locale = resolveLocale(
  Astro.cookies.get(LOCALE_COOKIE)?.value,
  Astro.request.headers.get('accept-language'),
);
---

<AdminLayout section="templates" title={t(locale, 'admin.nav.templates')}>
  <div class="mb-8 flex items-end justify-between gap-4">
    <div>
      <h1 class="text-2xl font-semibold tracking-tight">{t(locale, 'admin.nav.templates')}</h1>
      <p class="mt-1 text-sm text-muted">{t(locale, 'admin.hub.templates.desc')}</p>
    </div>
    <button type="button" id="btn-new" class="btn btn-primary shrink-0">
      {t(locale, 'admin.templates.new')}
    </button>
  </div>

  <p id="status" class="mb-5 hidden rounded-md px-4 py-2.5 text-sm" role="status"></p>

  <section class="card overflow-hidden">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-border text-left text-xs uppercase tracking-wide text-faint">
          <th class="px-5 py-3 font-medium">{t(locale, 'admin.templates.col.name')}</th>
          <th class="px-5 py-3 font-medium">{t(locale, 'admin.templates.col.status')}</th>
          <th class="px-5 py-3"></th>
        </tr>
      </thead>
      <tbody id="rows">
        <tr><td colspan="3" class="px-5 py-6 text-muted">{t(locale, 'action.loading')}</td></tr>
      </tbody>
    </table>
  </section>

  <section id="editor" class="card mt-8 p-6" hidden>
    <h2 id="editor-title" class="mb-4 text-lg font-semibold">{t(locale, 'admin.templates.editor.new')}</h2>
    <input type="hidden" id="f-id" />

    <!-- Part A — Meta -->
    <fieldset class="mb-6 rounded-lg border border-border p-5">
      <legend class="px-2 text-xs font-semibold uppercase tracking-wide text-accent">
        {t(locale, 'admin.templates.section.meta')}
      </legend>
      <div class="field">
        <label class="label" for="f-name">{t(locale, 'admin.templates.field.name')} <span class="text-danger">*</span></label>
        <input type="text" id="f-name" class="input" required />
      </div>
      <div class="field">
        <label class="label" for="f-description">{t(locale, 'admin.templates.field.description')}</label>
        <textarea id="f-description" class="input min-h-16" rows="2"></textarea>
      </div>
      <label class="flex items-center gap-2 text-sm font-medium text-fg">
        <input type="checkbox" id="f-enabled" class="size-4 accent-[var(--color-accent)]" />
        <span>{t(locale, 'admin.templates.field.enabled')}</span>
      </label>
    </fieldset>

    <!-- Part B — Ordered questions -->
    <fieldset class="mb-6 rounded-lg border border-border p-5">
      <legend class="px-2 text-xs font-semibold uppercase tracking-wide text-accent">
        {t(locale, 'admin.templates.section.questions')}
      </legend>
      <p class="hint mb-3" id="mem-hint">{t(locale, 'admin.templates.mem.hint')}</p>
      <div id="mem-area" hidden>
        <div class="mb-3 flex gap-2">
          <select id="mem-select" class="input flex-1"></select>
          <button type="button" id="btn-add-q" class="btn btn-ghost btn-sm shrink-0">
            {t(locale, 'admin.templates.mem.add')}
          </button>
        </div>
        <p class="hint mb-2">{t(locale, 'admin.templates.mem.drag_hint')}</p>
        <ol id="mem-list" class="mb-3 flex flex-col gap-1.5"></ol>
        <button type="button" id="btn-save-questions" class="btn btn-ghost btn-sm">
          {t(locale, 'admin.templates.mem.save')}
        </button>
      </div>
    </fieldset>

    <!-- Part C — Provider config -->
    <fieldset class="mb-6 rounded-lg border border-border p-5">
      <legend class="px-2 text-xs font-semibold uppercase tracking-wide text-accent">
        {t(locale, 'admin.templates.section.heygen')}
      </legend>
      <p class="hint mb-4">{t(locale, 'admin.templates.heygen.hint')}</p>
      <div class="grid grid-cols-[repeat(auto-fit,minmax(220px,1fr))] gap-x-5 gap-y-4" id="heygen-fields"></div>
    </fieldset>

    <fieldset class="mb-6 rounded-lg border border-border p-5">
      <legend class="px-2 text-xs font-semibold uppercase tracking-wide text-accent">
        {t(locale, 'admin.templates.section.tavus')}
      </legend>
      <div class="grid grid-cols-[repeat(auto-fit,minmax(220px,1fr))] gap-x-5 gap-y-4" id="tavus-fields"></div>
    </fieldset>

    <div class="flex gap-3">
      <button type="button" id="btn-save" class="btn btn-primary">{t(locale, 'admin.templates.save')}</button>
      <button type="button" id="btn-cancel" class="btn btn-ghost">{t(locale, 'action.cancel')}</button>
    </div>
  </section>

  <script>
    import { t, type Locale } from '../../lib/i18n';
    import { makeSortable } from '../../scripts/sortable';
    import {
      HEYGEN_FIELDS,
      TAVUS_FIELDS,
      validateProviderConfig,
      type FieldSpec,
      type Provider,
    } from '../../lib/provider-config';

    const locale = (document.documentElement.lang || 'it') as Locale;
    const API = '/api/admin/templates';
    const QAPI = '/api/admin/questions';
    const $ = (id: string) => document.getElementById(id) as HTMLElement;
    const statusEl = $('status');

    function flash(msg: string, ok = true) {
      statusEl.hidden = false;
      statusEl.textContent = msg;
      statusEl.className =
        'mb-5 rounded-md px-4 py-2.5 text-sm ' +
        (ok ? 'bg-success-soft text-success' : 'bg-danger-soft text-danger');
    }
    function clearFlash() {
      statusEl.hidden = true;
    }

    async function api(url: string, opts?: RequestInit) {
      const res = await fetch(url, opts);
      let data: any = null;
      try {
        data = await res.json();
      } catch {
        /* 204 */
      }
      if (!res.ok) throw new Error((data && data.error) || 'HTTP ' + res.status);
      return data;
    }

    // Provider-config field definitions live in the shared spec (src/lib/provider-config.ts),
    // the single source of truth for labels, constraints, validation, and the Tavus PAL
    // mapping. Here we only resolve the i18n label/hint keys and render the controls.

    // Build the form controls for a config section. Empty option lets selects be "unset".
    // Each field stacks: the control row, a help hint (its own line — hints are sentences),
    // and a hidden per-field error slot that validateConfigs() fills in.
    function buildFields(container: HTMLElement, fields: readonly FieldSpec[]) {
      container.innerHTML = '';
      for (const f of fields) {
        const wrap = document.createElement('div');
        wrap.className = 'flex flex-col gap-1';

        const cap = document.createElement('label');
        cap.className = 'text-sm font-medium text-fg';
        cap.textContent = t(locale, f.labelKey);

        let input: HTMLInputElement | HTMLSelectElement;
        if (f.type === 'select') {
          input = document.createElement('select');
          input.className = 'input';
          const blank = document.createElement('option');
          blank.value = '';
          blank.textContent = '—';
          input.appendChild(blank);
          for (const o of f.options ?? []) {
            const opt = document.createElement('option');
            opt.value = o;
            opt.textContent = o;
            input.appendChild(opt);
          }
        } else if (f.type === 'checkbox') {
          input = document.createElement('input');
          input.type = 'checkbox';
          input.className = 'size-4 accent-[var(--color-accent)]';
        } else if (f.type === 'number') {
          input = document.createElement('input');
          input.type = 'number';
          input.className = 'input';
          if (f.min !== undefined) input.min = String(f.min);
          if (f.max !== undefined) input.max = String(f.max);
          if (f.step !== undefined) input.step = String(f.step);
        } else {
          input = document.createElement('input');
          input.type = 'text';
          input.className = 'input';
        }
        input.dataset.key = f.key;
        input.dataset.type = f.type;

        // Control row: checkbox puts the box before the label; others stack label → input.
        const row = document.createElement('div');
        if (f.type === 'checkbox') {
          row.className = 'flex items-center gap-2';
          row.append(input, cap);
        } else {
          row.className = 'flex flex-col gap-1.5';
          row.append(cap, input);
        }
        wrap.appendChild(row);

        if (f.hintKey) {
          const h = document.createElement('p');
          h.className = 'text-xs leading-snug text-faint';
          h.textContent = t(locale, f.hintKey);
          wrap.appendChild(h);
        }

        const err = document.createElement('p');
        err.className = 'hidden text-xs font-medium';
        err.dataset.fieldError = f.key;
        wrap.appendChild(err);

        container.appendChild(wrap);
      }
    }

    // Populate a config section from a stored object (missing keys → left blank/default).
    function fillFields(container: HTMLElement, obj: Record<string, unknown> | null) {
      obj = obj || {};
      container.querySelectorAll<HTMLInputElement | HTMLSelectElement>('[data-key]').forEach((el) => {
        const key = el.dataset.key as string;
        const has = Object.prototype.hasOwnProperty.call(obj, key);
        if (el.dataset.type === 'checkbox') {
          (el as HTMLInputElement).checked = has ? !!obj![key] : false;
        } else {
          el.value = has && obj![key] != null ? String(obj![key]) : '';
        }
      });
    }

    // Serialize a config section into an object. Empty text/number/select fields are
    // OMITTED entirely (not stored as ''). Checkboxes always serialize as booleans.
    // Returns null when nothing was set, so we don't persist an empty {} blob.
    function collectFields(container: HTMLElement): Record<string, unknown> | null {
      const out: Record<string, unknown> = {};
      container.querySelectorAll<HTMLInputElement | HTMLSelectElement>('[data-key]').forEach((el) => {
        const key = el.dataset.key as string;
        const type = el.dataset.type;
        if (type === 'checkbox') {
          out[key] = (el as HTMLInputElement).checked;
        } else if (type === 'number') {
          const v = el.value.trim();
          if (v !== '') {
            const n = Number(v);
            if (!Number.isNaN(n)) out[key] = n;
          }
        } else {
          const v = el.value.trim();
          if (v !== '') out[key] = v;
        }
      });
      return Object.keys(out).length ? out : null;
    }

    // ── Config validation (shared spec) ──────────────────────────────────────────
    // Turn a validation code into a localized, non-technical message. Range errors
    // include the allowed interval so the operator knows the bounds.
    function errMessage(provider: Provider, key: string, code: string): string {
      const spec = (provider === 'heygen' ? HEYGEN_FIELDS : TAVUS_FIELDS).find((s) => s.key === key);
      if (code === 'range' && spec && (spec.min !== undefined || spec.max !== undefined)) {
        return t(locale, 'admin.cfg.err.range', { min: String(spec.min ?? '−∞'), max: String(spec.max ?? '∞') });
      }
      return t(locale, 'admin.cfg.err.' + code);
    }

    function clearFieldErrors(container: HTMLElement) {
      container.querySelectorAll<HTMLElement>('[data-field-error]').forEach((el) => {
        el.classList.add('hidden');
        el.classList.remove('text-danger', 'text-warning');
        el.textContent = '';
      });
    }

    // Validate both provider configs from the live form. Paints per-field notes and returns
    // counts. `hard` = real errors (type/range/enum) shown in danger and BLOCK the save;
    // `required` = missing recommended IDs shown in warning — allowed, they fall back to .env.
    function validateConfigs(): { hard: number; required: number } {
      let hard = 0;
      let required = 0;
      for (const provider of ['heygen', 'tavus'] as Provider[]) {
        const container = $(provider + '-fields');
        clearFieldErrors(container);
        const errors = validateProviderConfig(provider, collectFields(container));
        for (const e of errors) {
          const slot = container.querySelector<HTMLElement>('[data-field-error="' + e.key + '"]');
          if (slot) {
            slot.textContent = errMessage(provider, e.key, e.code);
            slot.classList.remove('hidden');
            slot.classList.add(e.code === 'required' ? 'text-warning' : 'text-danger');
          }
          if (e.code === 'required') required++;
          else hard++;
        }
      }
      return { hard, required };
    }

    // Classify a template's stored provider configs for the list badge: hard errors
    // (type/range/enum) → 'errors'; only missing required fields → 'incomplete'; else 'ok'.
    function configStatus(tpl: any): { label: string; cls: string } {
      const errors = [
        ...validateProviderConfig('heygen', tpl.heygen_config ?? null),
        ...validateProviderConfig('tavus', tpl.tavus_config ?? null),
      ];
      if (errors.some((e) => e.code !== 'required')) {
        return { label: t(locale, 'admin.templates.cfg.errors'), cls: 'badge bg-danger-soft text-danger' };
      }
      if (errors.length) {
        return { label: t(locale, 'admin.templates.cfg.incomplete'), cls: 'badge bg-warning/15 text-warning' };
      }
      return { label: t(locale, 'admin.templates.cfg.ok'), cls: 'badge bg-success-soft text-success' };
    }

    // ── List ────────────────────────────────────────────────────────────────────
    async function loadList() {
      const rows = $('rows');
      try {
        const list = await api(API);
        if (!list.length) {
          rows.innerHTML =
            '<tr><td colspan="3" class="px-5 py-10 text-center"><span class="block font-medium text-fg">' +
            t(locale, 'admin.templates.empty.title') +
            '</span><span class="mt-1 block text-sm text-muted">' +
            t(locale, 'admin.templates.empty.hint') +
            '</span></td></tr>';
          return;
        }
        rows.innerHTML = '';
        for (const tpl of list) {
          const on = tpl.enabled === 1 || tpl.enabled === true;
          const tr = document.createElement('tr');
          tr.className = 'border-b border-border last:border-0 hover:bg-panel';

          const name = document.createElement('td');
          name.className = 'px-5 py-3 font-medium text-fg';
          name.textContent = tpl.name;

          const st = document.createElement('td');
          st.className = 'px-5 py-3';
          const badgeRow = document.createElement('span');
          badgeRow.className = 'inline-flex flex-wrap items-center gap-1.5';
          const badge = document.createElement('span');
          badge.className = 'badge ' + (on ? 'badge-on' : 'badge-off');
          badge.textContent = on ? t(locale, 'state.enabled') : t(locale, 'state.disabled');
          const cfg = configStatus(tpl);
          const cfgBadge = document.createElement('span');
          cfgBadge.className = cfg.cls;
          cfgBadge.textContent = cfg.label;
          badgeRow.append(badge, cfgBadge);
          st.appendChild(badgeRow);

          const act = document.createElement('td');
          act.className = 'px-5 py-3 text-right whitespace-nowrap';
          const edit = document.createElement('button');
          edit.className = 'btn btn-ghost btn-sm';
          edit.textContent = t(locale, 'action.edit');
          edit.onclick = () => openEdit(tpl.id);
          const del = document.createElement('button');
          del.className = 'btn btn-danger btn-sm ml-1.5';
          del.textContent = t(locale, 'action.delete');
          del.onclick = () => remove(tpl.id, tpl.name);
          act.append(edit, del);

          tr.append(name, st, act);
          rows.appendChild(tr);
        }
      } catch (e: any) {
        rows.innerHTML = '<tr><td colspan="3" class="px-5 py-6 text-danger">' + e.message + '</td></tr>';
      }
    }

    // ── Ordered membership editor ────────────────────────────────────────────────
    // enabledQuestions: id -> { id, name } for all currently-enabled questions.
    // memberIds: ordered array of selected question ids (the working state).
    let enabledQuestions = new Map<number, { id: number; name: string }>();
    let memberIds: number[] = [];

    async function loadEnabledQuestions() {
      const list = await api(QAPI);
      enabledQuestions = new Map();
      for (const q of list) {
        if (q.enabled === 1 || q.enabled === true) {
          enabledQuestions.set(q.id, { id: q.id, name: q.name });
        }
      }
    }

    function renderMembership() {
      // The add-select shows only enabled questions not already in the list.
      const sel = $('mem-select') as HTMLSelectElement;
      sel.innerHTML = '';
      const available = [...enabledQuestions.values()].filter((q) => !memberIds.includes(q.id));
      if (!available.length) {
        const o = document.createElement('option');
        o.value = '';
        o.textContent = t(locale, 'admin.templates.mem.none_available');
        sel.appendChild(o);
        ($('btn-add-q') as HTMLButtonElement).disabled = true;
      } else {
        ($('btn-add-q') as HTMLButtonElement).disabled = false;
        for (const q of available) {
          const o = document.createElement('option');
          o.value = String(q.id);
          o.textContent = q.name;
          sel.appendChild(o);
        }
      }

      const list = $('mem-list');
      list.innerHTML = '';
      if (!memberIds.length) {
        const li = document.createElement('li');
        li.className = 'list-none text-sm text-muted';
        li.textContent = t(locale, 'admin.templates.mem.empty');
        list.appendChild(li);
        return;
      }
      memberIds.forEach((id) => {
        const meta = enabledQuestions.get(id);
        const li = document.createElement('li');
        li.className = 'sortable-item list-none';
        li.draggable = true;
        li.dataset.sortableItem = '';
        li.dataset.sortableKey = String(id);

        const left = document.createElement('span');
        left.className = 'flex min-w-0 items-center gap-2.5';
        const handle = document.createElement('span');
        handle.className = 'drag-handle';
        handle.textContent = '⠿';
        handle.setAttribute('aria-hidden', 'true');
        const label = document.createElement('span');
        label.className = 'truncate text-sm';
        // A member id may no longer be enabled (e.g. disabled after selection) — flag it.
        label.textContent = meta ? meta.name : t(locale, 'admin.templates.mem.not_enabled', { id });
        if (!meta) label.classList.add('text-danger');
        left.append(handle, label);

        const rm = document.createElement('button');
        rm.type = 'button';
        rm.className = 'btn btn-danger btn-sm px-2 shrink-0';
        rm.textContent = '✕';
        rm.onclick = () => {
          const at = memberIds.indexOf(id);
          if (at !== -1) memberIds.splice(at, 1);
          renderMembership();
        };

        li.append(left, rm);
        list.appendChild(li);
      });
    }

    ($('btn-add-q') as HTMLButtonElement).onclick = () => {
      const v = ($('mem-select') as HTMLSelectElement).value;
      if (!v) return;
      const id = Number(v);
      if (!memberIds.includes(id)) memberIds.push(id);
      renderMembership();
    };

    // Drag & drop reordering — the single reusable mechanism. Attached once; the
    // list re-renders its children freely (event delegation survives that).
    makeSortable($('mem-list'), {
      onReorder: (keys) => {
        memberIds = keys.map(Number);
        renderMembership();
      },
    });

    async function saveQuestions() {
      const id = ($('f-id') as HTMLInputElement).value;
      if (!id) return;
      try {
        await api(API + '/' + id + '/questions', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ questionIds: memberIds }),
        });
        flash(t(locale, 'admin.templates.msg.order_saved'));
      } catch (e: any) {
        flash(e.message, false);
      }
    }
    ($('btn-save-questions') as HTMLButtonElement).onclick = saveQuestions;

    // ── Open / edit ──────────────────────────────────────────────────────────────
    function openNew() {
      clearFlash();
      $('editor-title').textContent = t(locale, 'admin.templates.editor.new');
      ($('f-id') as HTMLInputElement).value = '';
      ($('f-name') as HTMLInputElement).value = '';
      ($('f-description') as HTMLTextAreaElement).value = '';
      ($('f-enabled') as HTMLInputElement).checked = false;
      buildFields($('heygen-fields'), HEYGEN_FIELDS);
      buildFields($('tavus-fields'), TAVUS_FIELDS);
      fillFields($('heygen-fields'), null);
      fillFields($('tavus-fields'), null);
      // Membership editing needs a saved template id.
      memberIds = [];
      $('mem-area').hidden = true;
      $('mem-hint').hidden = false;
      $('editor').hidden = false;
      ($('f-name') as HTMLInputElement).focus();
    }

    async function openEdit(id: number) {
      clearFlash();
      try {
        const tpl = await api(API + '/' + id);
        $('editor-title').textContent = t(locale, 'admin.templates.editor.edit', { id: tpl.id });
        ($('f-id') as HTMLInputElement).value = String(tpl.id);
        ($('f-name') as HTMLInputElement).value = tpl.name || '';
        ($('f-description') as HTMLTextAreaElement).value = tpl.description || '';
        ($('f-enabled') as HTMLInputElement).checked = tpl.enabled === 1 || tpl.enabled === true;

        buildFields($('heygen-fields'), HEYGEN_FIELDS);
        buildFields($('tavus-fields'), TAVUS_FIELDS);
        fillFields($('heygen-fields'), tpl.heygen_config);
        fillFields($('tavus-fields'), tpl.tavus_config);

        await loadEnabledQuestions();
        const members = await api(API + '/' + id + '/questions');
        memberIds = members.map((q: any) => q.id);
        // Membered questions may not be in the enabled set — keep them addressable.
        for (const q of members) {
          if (!enabledQuestions.has(q.id)) {
            enabledQuestions.set(q.id, { id: q.id, name: q.name });
          }
        }
        renderMembership();
        $('mem-area').hidden = false;
        $('mem-hint').hidden = true;

        $('editor').hidden = false;
        window.scrollTo({ top: 0, behavior: 'smooth' });
      } catch (e: any) {
        flash(e.message, false);
      }
    }

    async function saveTemplate() {
      const id = ($('f-id') as HTMLInputElement).value;
      const name = ($('f-name') as HTMLInputElement).value.trim();
      if (!name) {
        flash(t(locale, 'admin.templates.field.name') + ' *', false);
        return;
      }
      // Block only on hard config errors (type/range/enum); missing recommended IDs are
      // allowed (they fall back to .env at runtime). Per-field notes are painted here.
      const { hard } = validateConfigs();
      if (hard > 0) {
        flash(t(locale, 'admin.cfg.err.summary', { count: String(hard) }), false);
        return;
      }
      const payload = {
        name,
        description: ($('f-description') as HTMLTextAreaElement).value.trim() || null,
        enabled: ($('f-enabled') as HTMLInputElement).checked,
        heygenConfig: collectFields($('heygen-fields')),
        tavusConfig: collectFields($('tavus-fields')),
      };
      // A PAL warning is non-fatal (the template still saved) but needs attention.
      const savedFlash = (msgKey: string, palWarning?: string) => {
        if (palWarning) flash(t(locale, msgKey) + ' ⚠ ' + palWarning, false);
        else flash(t(locale, msgKey));
      };
      try {
        if (id) {
          const data = await api(API + '/' + id, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          // Reflect any freshly-created palId back into the form, so a second save PATCHes
          // the same PAL instead of creating a duplicate.
          if (data && data.tavus_config) fillFields($('tavus-fields'), data.tavus_config);
          savedFlash('admin.templates.msg.saved', data && data.palWarning);
          loadList();
        } else {
          const created = await api(API, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          savedFlash('admin.templates.msg.created', created && created.palWarning);
          loadList();
          // Reopen in edit mode so the operator can now manage membership.
          if (created && created.id) openEdit(created.id);
        }
      } catch (e: any) {
        flash(e.message, false);
      }
    }
    ($('btn-save') as HTMLButtonElement).onclick = saveTemplate;

    async function remove(id: number, name: string) {
      if (!confirm(t(locale, 'admin.templates.confirm_delete', { name }))) return;
      try {
        await api(API + '/' + id, { method: 'DELETE' });
        flash(t(locale, 'admin.templates.msg.deleted'));
        $('editor').hidden = true;
        loadList();
      } catch (e: any) {
        flash(e.message, false);
      }
    }

    ($('btn-new') as HTMLButtonElement).onclick = openNew;
    ($('btn-cancel') as HTMLButtonElement).onclick = () => {
      $('editor').hidden = true;
      clearFlash();
    };

    loadList();
  </script>
</AdminLayout>
