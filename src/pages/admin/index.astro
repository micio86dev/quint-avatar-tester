---
// Operator admin hub. A considered landing that links to the four sections
// (prompts, questions, templates, sessions), each with a one-line description and
// its current count resolved server-side. The whole /admin area sits behind the
// password middleware, so no auth here.
import AdminLayout from '../../layouts/AdminLayout.astro';
import { resolveLocale, t, LOCALE_COOKIE, type Locale } from '../../lib/i18n';
import { countPrompts, countQuestions, countTemplates, listSessions } from '../../lib/db';

export const prerender = false;

const locale: Locale = resolveLocale(
  Astro.cookies.get(LOCALE_COOKIE)?.value,
  Astro.request.headers.get('accept-language'),
);

// Human-friendly count label with singular / zero variants.
function countLabel(n: number): string {
  if (n === 0) return t(locale, 'admin.hub.count_zero');
  if (n === 1) return t(locale, 'admin.hub.count_one');
  return t(locale, 'admin.hub.count', { n });
}

const sections = [
  { key: 'prompts', href: '/admin/prompts', count: countPrompts() },
  { key: 'questions', href: '/admin/questions', count: countQuestions() },
  { key: 'templates', href: '/admin/templates', count: countTemplates() },
  { key: 'sessions', href: '/admin/sessions', count: listSessions().length },
] as const;
---

<AdminLayout title={t(locale, 'admin.title')}>
  <div class="mb-10">
    <h1 class="text-2xl font-semibold tracking-tight">{t(locale, 'admin.title')}</h1>
    <p class="mt-2 max-w-2xl text-muted">{t(locale, 'admin.subtitle')}</p>
  </div>

  <div class="flex flex-col divide-y divide-border overflow-hidden rounded-lg border border-border bg-surface">
    {
      sections.map((s) => (
        <a
          href={s.href}
          class="group flex items-center gap-5 px-5 py-5 transition-colors hover:bg-panel"
        >
          <div class="min-w-0 flex-1">
            <div class="flex items-baseline gap-3">
              <span class="text-base font-semibold text-fg">{t(locale, `admin.nav.${s.key}`)}</span>
              <span class="text-xs text-faint tabular-nums">{countLabel(s.count)}</span>
            </div>
            <p class="mt-1 text-sm text-muted">{t(locale, `admin.hub.${s.key}.desc`)}</p>
          </div>
          <span class="shrink-0 text-sm font-medium text-muted transition-colors group-hover:text-accent">
            {t(locale, 'admin.hub.open')} <span aria-hidden="true">&rarr;</span>
          </span>
        </a>
      ))
    }
  </div>
</AdminLayout>
