---
// Operator admin hub. Links to the three CRUD sections (prompts, questions,
// templates) that manage the interview catalog via the /api/admin/* JSON API.
// The whole /admin area sits behind the password middleware, so no auth here.
export const prerender = false;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Admin — BEAI</title>
  </head>
  <body>
    <main>
      <header>
        <h1>Admin</h1>
        <a href="/" class="back">← Home</a>
      </header>

      <p class="intro">
        Manage the interview catalog: persona prompts, the question bank, and the
        experiment templates that combine ordered questions with provider config.
      </p>

      <nav class="cards">
        <a href="/admin/prompts" class="card">
          <h2>Prompts</h2>
          <p>Persona prompts and scripts (title, body, greeting, language, notes).</p>
        </a>
        <a href="/admin/questions" class="card">
          <h2>Questions</h2>
          <p>The interview question bank. Enable/disable and edit questions.</p>
        </a>
        <a href="/admin/templates" class="card">
          <h2>Templates</h2>
          <p>Experiment recipes: ordered questions plus HeyGen / Tavus provider config.</p>
        </a>
      </nav>

      <p class="legacy">
        <a href="/admin" class="muted">Candidate archive lives on the legacy pages.</a>
      </p>
    </main>

    <style>
      :global(body) {
        margin: 0;
        background: #0b0c10;
        color: #e8eaed;
        font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
      }
      main {
        max-width: 900px;
        margin: 0 auto;
        padding: 32px 20px 64px;
      }
      header {
        display: flex;
        align-items: baseline;
        gap: 20px;
        margin-bottom: 20px;
      }
      h1 {
        margin: 0;
        font-size: 1.5rem;
      }
      .back {
        color: #6b7280;
        font-size: 0.85rem;
        text-decoration: none;
      }
      .back:hover { color: #9aa0aa; }
      .intro {
        color: #9aa0aa;
        font-size: 0.95rem;
        margin: 0 0 28px;
        max-width: 640px;
      }
      .cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 16px;
      }
      .card {
        display: block;
        padding: 20px;
        border: 1px solid #2a2c36;
        border-radius: 12px;
        text-decoration: none;
        color: inherit;
        background: #12131a;
        transition: border-color 0.15s, transform 0.1s;
      }
      .card:hover {
        border-color: #10b981;
        transform: translateY(-2px);
      }
      .card h2 {
        margin: 0 0 6px;
        font-size: 1.1rem;
        color: #a7f3d0;
      }
      .card p {
        margin: 0;
        font-size: 0.85rem;
        color: #9aa0aa;
        line-height: 1.4;
      }
      .legacy {
        margin-top: 32px;
        font-size: 0.8rem;
      }
      .muted { color: #4b5563; text-decoration: none; }
      .muted:hover { color: #9aa0aa; }
    </style>
  </body>
</html>
