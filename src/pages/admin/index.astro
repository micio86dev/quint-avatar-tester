---
import { getAllCandidates } from '../../lib/db';
import { rates } from '../../lib/pricing';
import { t, formatDateTime } from '../../lib/i18n';

export const prerender = false;

const candidates = getAllCandidates();

function calcCost(heygenMin: number, tavusMin: number): number {
  const heygenUsd = heygenMin * rates.heygenCreditsPerMin * rates.heygenUsdPerCredit;
  const tavusUsd = tavusMin > 0
    ? Math.max(0.5, Math.ceil(tavusMin * 600) / 600) * rates.tavusUsdPerMin
    : 0;
  return heygenUsd + tavusUsd;
}

function formatProviders(raw: string | null): string[] {
  if (!raw) return [];
  return [...new Set(raw.split(','))];
}
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{t('admin.list.title')}</title>
  </head>
  <body>
    <main>
      <header>
        <h1>{t('admin.list.title')}</h1>
        <a href="/" class="back">{t('nav.back_home')}</a>
      </header>

      {candidates.length === 0 && <p class="empty">{t('admin.list.empty')}</p>}

      {candidates.length > 0 && (
        <table>
          <thead>
            <tr>
              <th>{t('admin.list.col.candidate')}</th>
              <th>{t('admin.list.col.code')}</th>
              <th>{t('admin.list.col.progress')}</th>
              <th>{t('admin.list.col.provider')}</th>
              <th>{t('admin.list.col.cost')}</th>
              <th>{t('admin.list.col.last_activity')}</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            {candidates.map((c) => {
              const completed = Number(c.completed_questions);
              const total = Number(c.total_questions);
              const pct = total > 0 ? Math.round((completed / total) * 100) : 0;
              const done = completed === total && total > 0;
              const providers = formatProviders(c.providers_used);
              const costUsd = calcCost(Number(c.total_heygen_min), Number(c.total_tavus_min));
              const heygenCredits = Number(c.total_heygen_min) * rates.heygenCreditsPerMin;
              return (
                <tr>
                  <td class="name">{c.display_name ?? '—'}</td>
                  <td class="code">{c.resume_code}</td>
                  <td class="progress">
                    <div class="bar-wrap">
                      <div class="bar-fill" style={`width:${pct}%`}></div>
                    </div>
                    <span class={`prog-label ${done ? 'done' : ''}`}>{completed}/{total}</span>
                  </td>
                  <td class="providers">
                    {providers.map((p) => (
                      <span class={`badge-prov badge-${p}`}>{p}</span>
                    ))}
                    {providers.length === 0 && <span class="no-prov">—</span>}
                  </td>
                  <td class="cost-col">
                    {costUsd > 0 ? (
                      <span class="cost-val">
                        ${costUsd.toFixed(2)}
                        {heygenCredits > 0 && (
                          <span class="cost-detail"> · {Math.round(heygenCredits)} cr HeyGen</span>
                        )}
                        {Number(c.total_tavus_min) > 0 && (
                          <span class="cost-detail"> · {Number(c.total_tavus_min).toFixed(1)}m Tavus</span>
                        )}
                      </span>
                    ) : (
                      <span class="no-prov">—</span>
                    )}
                  </td>
                  <td class="date">{formatDateTime(c.last_activity)}</td>
                  <td class="action">
                    <a href={`/admin/${c.resume_code}`} class="btn-detail">{t('admin.list.action.detail')}</a>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      )}
    </main>

    <style>
      :global(body) {
        margin: 0;
        background: #0b0c10;
        color: #e8eaed;
        font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
      }
      main {
        max-width: 1000px;
        margin: 0 auto;
        padding: 32px 20px 64px;
      }
      header {
        display: flex;
        align-items: baseline;
        gap: 20px;
        margin-bottom: 28px;
      }
      h1 {
        margin: 0;
        font-size: 1.5rem;
      }
      .back {
        color: #6b7280;
        font-size: 0.85rem;
        text-decoration: none;
      }
      .back:hover { color: #9aa0aa; }
      .empty { color: #6b7280; }

      table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.88rem;
      }
      thead th {
        text-align: left;
        padding: 8px 12px;
        color: #6b7280;
        font-weight: 600;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        border-bottom: 1px solid #2a2c36;
      }
      tbody tr {
        border-bottom: 1px solid #1c1e27;
        transition: background 0.1s;
      }
      tbody tr:hover { background: #12131a; }
      td {
        padding: 12px 12px;
        vertical-align: middle;
      }
      .name { font-weight: 600; }
      .code {
        font-family: monospace;
        color: #a7f3d0;
        letter-spacing: 0.06em;
      }
      .progress {
        display: flex;
        align-items: center;
        gap: 10px;
        min-width: 120px;
      }
      .bar-wrap {
        flex: 1;
        height: 6px;
        background: #2a2c36;
        border-radius: 3px;
        overflow: hidden;
      }
      .bar-fill {
        height: 100%;
        background: #10b981;
        border-radius: 3px;
      }
      .prog-label {
        color: #9aa0aa;
        font-size: 0.8rem;
        white-space: nowrap;
        font-variant-numeric: tabular-nums;
      }
      .prog-label.done { color: #10b981; }
      .providers {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
      }
      .badge-prov {
        padding: 2px 8px;
        border-radius: 999px;
        font-size: 0.68rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.04em;
      }
      .badge-heygen { background: #10b981; color: #04150f; }
      .badge-tavus  { background: #818cf8; color: #0d0e24; }
      .no-prov { color: #4b5563; }
      .cost-col { white-space: nowrap; }
      .cost-val {
        color: #a7f3d0;
        font-weight: 600;
        font-variant-numeric: tabular-nums;
      }
      .cost-detail {
        color: #6b7280;
        font-weight: 400;
        font-size: 0.8em;
      }
      .date { color: #6b7280; font-size: 0.82rem; white-space: nowrap; }
      .action { text-align: right; }
      .btn-detail {
        display: inline-block;
        padding: 4px 14px;
        border: 1px solid #2a2c36;
        border-radius: 8px;
        color: #a7f3d0;
        font-size: 0.82rem;
        text-decoration: none;
        transition: border-color 0.15s, color 0.15s;
      }
      .btn-detail:hover {
        border-color: #10b981;
        color: #10b981;
      }
    </style>
  </body>
</html>
