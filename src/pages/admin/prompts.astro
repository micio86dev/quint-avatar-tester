---
// Prompts CRUD. Lists persona prompts and provides a create/edit form.
// Talks to /api/admin/prompts (list/create) and /api/admin/prompts/[id]
// (get/update/delete). All client logic is vanilla fetch, no framework.
import AdminLayout from '../../layouts/AdminLayout.astro';
import { resolveLocale, t, LOCALE_COOKIE, type Locale } from '../../lib/i18n';

export const prerender = false;

const locale: Locale = resolveLocale(
  Astro.cookies.get(LOCALE_COOKIE)?.value,
  Astro.request.headers.get('accept-language'),
);
---

<AdminLayout section="prompts" title={t(locale, 'admin.nav.prompts')}>
  <div class="mb-8 flex items-end justify-between gap-4">
    <div>
      <h1 class="text-2xl font-semibold tracking-tight">{t(locale, 'admin.nav.prompts')}</h1>
      <p class="mt-1 text-sm text-muted">{t(locale, 'admin.hub.prompts.desc')}</p>
    </div>
    <button type="button" id="btn-new" class="btn btn-primary shrink-0">
      {t(locale, 'admin.prompts.new')}
    </button>
  </div>

  <p id="status" class="mb-5 hidden rounded-md px-4 py-2.5 text-sm" role="status"></p>

  <section class="card overflow-hidden">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-border text-left text-xs uppercase tracking-wide text-faint">
          <th class="px-5 py-3 font-medium">{t(locale, 'admin.prompts.col.title')}</th>
          <th class="px-5 py-3 font-medium">{t(locale, 'admin.prompts.col.language')}</th>
          <th class="px-5 py-3 font-medium">{t(locale, 'admin.prompts.col.updated')}</th>
          <th class="px-5 py-3"></th>
        </tr>
      </thead>
      <tbody id="rows">
        <tr><td colspan="4" class="px-5 py-6 text-muted">{t(locale, 'action.loading')}</td></tr>
      </tbody>
    </table>
  </section>

  <section id="editor" class="card mt-8 p-6" hidden>
    <h2 id="editor-title" class="mb-5 text-lg font-semibold">{t(locale, 'admin.prompts.editor.new')}</h2>
    <form id="form" novalidate>
      <input type="hidden" id="f-id" />
      <div class="field">
        <label class="label" for="f-title">{t(locale, 'admin.prompts.field.title')} <span class="text-danger">*</span></label>
        <input type="text" id="f-title" class="input" required />
        <p class="mt-1 hidden text-xs font-medium text-danger" data-error-for="f-title"></p>
      </div>
      <div class="field">
        <label class="label" for="f-body">{t(locale, 'admin.prompts.field.body')} <span class="text-danger">*</span></label>
        <textarea id="f-body" class="input" rows="8" required></textarea>
        <p class="hint">{t(locale, 'admin.prompts.field.body.hint')}</p>
        <p class="mt-1 hidden text-xs font-medium text-danger" data-error-for="f-body"></p>
      </div>
      <div class="field">
        <label class="label" for="f-greeting">{t(locale, 'admin.prompts.field.greeting')}</label>
        <input type="text" id="f-greeting" class="input" />
        <p class="hint">{t(locale, 'admin.prompts.field.greeting.hint')}</p>
      </div>
      <div class="field">
        <label class="label" for="f-language">{t(locale, 'admin.prompts.field.language')}</label>
        <select id="f-language" class="input max-w-40">
          <option value="it">it</option>
          <option value="en">en</option>
        </select>
      </div>
      <div class="field">
        <label class="label" for="f-notes">{t(locale, 'admin.prompts.field.notes')}</label>
        <textarea id="f-notes" class="input min-h-20" rows="3"></textarea>
      </div>
      <p id="form-status" class="mb-3 hidden rounded-md px-4 py-2.5 text-sm" role="alert"></p>
      <div class="flex gap-3 pt-1">
        <button type="submit" class="btn btn-primary">{t(locale, 'action.save')}</button>
        <button type="button" id="btn-cancel" class="btn btn-ghost">{t(locale, 'action.cancel')}</button>
      </div>
    </form>
  </section>

  <script>
    import { t, type Locale } from '../../lib/i18n';
    import { confirmDialog } from '../../scripts/modal';

    const locale = (document.documentElement.lang || 'it') as Locale;
    const API = '/api/admin/prompts';
    const $ = (id: string) => document.getElementById(id) as HTMLElement;
    const statusEl = $('status');
    const formStatusEl = $('form-status');

    // Top status: list-context feedback (duplicate/delete) shown with the editor closed.
    function flash(msg: string, ok = true) {
      statusEl.hidden = false;
      statusEl.textContent = msg;
      statusEl.className =
        'mb-5 rounded-md px-4 py-2.5 text-sm ' +
        (ok ? 'bg-success-soft text-success' : 'bg-danger-soft text-danger');
    }
    function clearFlash() {
      statusEl.hidden = true;
    }

    // Form status: save/validation feedback shown right next to the Save button.
    function flashForm(msg: string, ok = true) {
      formStatusEl.hidden = false;
      formStatusEl.textContent = msg;
      formStatusEl.className =
        'mb-3 rounded-md px-4 py-2.5 text-sm ' +
        (ok ? 'bg-success-soft text-success' : 'bg-danger-soft text-danger');
    }
    function clearForm() {
      formStatusEl.hidden = true;
    }

    // Per-field error notes under each input, toggled with aria-invalid for a11y.
    const REQUIRED_FIELDS = ['f-title', 'f-body'];
    function setFieldError(id: string, msg: string) {
      const slot = document.querySelector<HTMLElement>('[data-error-for="' + id + '"]');
      if (slot) {
        slot.textContent = msg;
        slot.classList.remove('hidden');
      }
      $(id)?.setAttribute('aria-invalid', 'true');
    }
    function clearFieldErrors() {
      document.querySelectorAll<HTMLElement>('[data-error-for]').forEach((el) => {
        el.textContent = '';
        el.classList.add('hidden');
      });
      REQUIRED_FIELDS.forEach((id) => $(id)?.removeAttribute('aria-invalid'));
    }

    async function api(url: string, opts?: RequestInit) {
      // Always tag requests as JSON. Same-origin this is a no-op, but it exempts our
      // bodyless mutations (DELETE, duplicate POST) from Astro's checkOrigin CSRF guard,
      // which otherwise 403s them behind a reverse proxy where Origin ≠ internal host.
      const res = await fetch(url, {
        ...opts,
        headers: { 'Content-Type': 'application/json', ...(opts?.headers as Record<string, string> | undefined) },
      });
      let data: any = null;
      try {
        data = await res.json();
      } catch {
        /* 204 etc. */
      }
      if (!res.ok) throw new Error((data && data.error) || 'HTTP ' + res.status);
      return data;
    }

    function fmtDate(s: string | null) {
      if (!s) return '—';
      const d = new Date(s);
      return isNaN(d.getTime()) ? s : new Intl.DateTimeFormat(locale, { dateStyle: 'medium', timeStyle: 'short' }).format(d);
    }

    async function loadList() {
      const rows = $('rows');
      try {
        const list = await api(API);
        if (!list.length) {
          rows.innerHTML =
            '<tr><td colspan="4" class="px-5 py-10 text-center"><span class="block font-medium text-fg">' +
            t(locale, 'admin.prompts.empty.title') +
            '</span><span class="mt-1 block text-sm text-muted">' +
            t(locale, 'admin.prompts.empty.hint') +
            '</span></td></tr>';
          return;
        }
        rows.innerHTML = '';
        for (const p of list) {
          const tr = document.createElement('tr');
          tr.className = 'border-b border-border last:border-0 hover:bg-panel';

          const title = document.createElement('td');
          title.className = 'px-5 py-3 font-medium text-fg';
          title.textContent = p.title;

          const lang = document.createElement('td');
          lang.className = 'px-5 py-3 text-muted';
          lang.textContent = p.language || '—';

          const upd = document.createElement('td');
          upd.className = 'px-5 py-3 whitespace-nowrap text-faint tabular-nums';
          upd.textContent = fmtDate(p.updated_at);

          const act = document.createElement('td');
          act.className = 'px-5 py-3 text-right whitespace-nowrap';
          const edit = document.createElement('button');
          edit.className = 'btn btn-ghost btn-sm';
          edit.textContent = t(locale, 'action.edit');
          edit.onclick = () => openEdit(p.id);
          const dup = document.createElement('button');
          dup.className = 'btn btn-ghost btn-sm ml-1.5';
          dup.textContent = t(locale, 'action.duplicate');
          dup.onclick = () => duplicate(p.id);
          const del = document.createElement('button');
          del.className = 'btn btn-danger btn-sm ml-1.5';
          del.textContent = t(locale, 'action.delete');
          del.onclick = () => remove(p.id, p.title);
          act.append(edit, dup, del);

          tr.append(title, lang, upd, act);
          rows.appendChild(tr);
        }
      } catch (e: any) {
        rows.innerHTML = '<tr><td colspan="4" class="px-5 py-6 text-danger">' + e.message + '</td></tr>';
      }
    }

    function openNew() {
      clearFlash();
      clearForm();
      clearFieldErrors();
      $('editor-title').textContent = t(locale, 'admin.prompts.editor.new');
      ($('f-id') as HTMLInputElement).value = '';
      ($('form') as HTMLFormElement).reset();
      ($('f-language') as HTMLSelectElement).value = 'it';
      $('editor').hidden = false;
      ($('f-title') as HTMLInputElement).focus();
    }

    async function openEdit(id: number) {
      clearFlash();
      clearForm();
      clearFieldErrors();
      try {
        const p = await api(API + '/' + id);
        $('editor-title').textContent = t(locale, 'admin.prompts.editor.edit', { id: p.id });
        ($('f-id') as HTMLInputElement).value = String(p.id);
        ($('f-title') as HTMLInputElement).value = p.title || '';
        ($('f-body') as HTMLTextAreaElement).value = p.body || '';
        ($('f-greeting') as HTMLInputElement).value = p.greeting || '';
        ($('f-language') as HTMLSelectElement).value = p.language || 'it';
        ($('f-notes') as HTMLTextAreaElement).value = p.notes || '';
        $('editor').hidden = false;
        window.scrollTo({ top: document.body.scrollHeight, behavior: 'smooth' });
      } catch (e: any) {
        flash(e.message, false);
      }
    }

    async function duplicate(id: number) {
      clearFlash();
      try {
        await api(API + '/' + id + '/duplicate', { method: 'POST' });
        flash(t(locale, 'action.duplicated'));
        loadList();
      } catch (e: any) {
        flash(e.message, false);
      }
    }

    async function remove(id: number, title: string) {
      const ok = await confirmDialog({
        title: t(locale, 'action.confirm_title'),
        message: t(locale, 'admin.prompts.confirm_delete', { title }),
        confirmLabel: t(locale, 'action.delete'),
        cancelLabel: t(locale, 'action.cancel'),
        tone: 'danger',
      });
      if (!ok) return;
      try {
        await api(API + '/' + id, { method: 'DELETE' });
        flash(t(locale, 'admin.prompts.msg.deleted'));
        loadList();
      } catch (e: any) {
        flash(e.message, false);
      }
    }

    ($('form') as HTMLFormElement).addEventListener('submit', async (ev) => {
      ev.preventDefault();
      clearForm();
      clearFieldErrors();
      const id = ($('f-id') as HTMLInputElement).value;
      const title = ($('f-title') as HTMLInputElement).value.trim();
      const body = ($('f-body') as HTMLTextAreaElement).value;
      // Client-side required checks, painted per field near the Save button.
      let firstBad: string | null = null;
      if (!title) { setFieldError('f-title', t(locale, 'admin.form.err.required')); firstBad ??= 'f-title'; }
      if (!body.trim()) { setFieldError('f-body', t(locale, 'admin.form.err.required')); firstBad ??= 'f-body'; }
      if (firstBad) {
        flashForm(t(locale, 'admin.form.err.fix'), false);
        $(firstBad).focus();
        return;
      }
      const payload = {
        title,
        body,
        greeting: ($('f-greeting') as HTMLInputElement).value.trim() || null,
        language: ($('f-language') as HTMLSelectElement).value.trim() || 'it',
        notes: ($('f-notes') as HTMLTextAreaElement).value.trim() || null,
      };
      try {
        if (id) {
          await api(API + '/' + id, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          flash(t(locale, 'admin.prompts.msg.saved'));
        } else {
          await api(API, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          flash(t(locale, 'admin.prompts.msg.created'));
        }
        $('editor').hidden = true;
        loadList();
      } catch (e: any) {
        flashForm(e.message, false);
      }
    });

    ($('btn-new') as HTMLButtonElement).onclick = openNew;
    ($('btn-cancel') as HTMLButtonElement).onclick = () => {
      $('editor').hidden = true;
      clearFlash();
      clearForm();
      clearFieldErrors();
    };

    loadList();
  </script>
</AdminLayout>
