---
// Single continuous avatar interview across two interchangeable providers
// (HeyGen | Tavus), driven by a prompt (persona) × template (questions + provider config).
// The operator picks a prompt and a template, then runs ONE timed session end-to-end.
// Every utterance is persisted to local SQLite. The page is a small three-screen state
// machine (start → interview → done) that never scrolls on Y.
//
// This is an operator test tool: the UI copy is English; only the avatar's spoken
// content stays Italian.
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>Interview Tester — HeyGen / Tavus</title>
  </head>
  <body>
    <main class="app" id="app" data-screen="start">
      <!-- ── START ─────────────────────────────────────────────────────────── -->
      <section class="screen panel" id="screen-start">
        <h1 class="brand">Interview Tester</h1>

        <div class="provider-toggle" role="radiogroup" aria-label="Provider">
          <label>
            <input type="radio" name="provider" value="heygen" checked />
            <span>HeyGen</span>
          </label>
          <label>
            <input type="radio" name="provider" value="tavus" />
            <span>Tavus</span>
          </label>
        </div>

        <div class="selectors">
          <label class="field">
            <span class="field-label">Prompt (persona)</span>
            <select id="prompt-select" class="select">
              <option value="">Loading…</option>
            </select>
          </label>
          <label class="field">
            <span class="field-label">Template (questions)</span>
            <select id="template-select" class="select">
              <option value="">Loading…</option>
            </select>
          </label>
        </div>

        <label class="consent">
          <input type="checkbox" id="consent" />
          <span
            >This is a test session. You will speak with an AI interviewer; the
            conversation is transcribed and stored locally for analysis. During the
            interview the session is monitored for integrity: the webcam stays active and
            presence/attention signals are recorded (no image leaves this device). By
            continuing, you consent.</span
          >
        </label>

        <button type="button" id="btn-start" class="btn primary" disabled>Start interview</button>

        <p id="start-error" class="error-line"></p>
        <a href="/admin" class="admin-link">Interview archive →</a>
      </section>

      <!-- ── INTERVIEW ─────────────────────────────────────────────────────────── -->
      <div class="screen interview" id="screen-interview">
        <header class="topbar">
          <span class="timer" id="timer" data-warn="normal">—:——</span>
        </header>

        <section class="stage">
          <!-- Audio is attached to this same element, so it must NOT be muted. -->
          <video id="avatar-video" autoplay playsinline></video>

          <div id="meter" class="meter" hidden>
            <span class="meter-icon">⚡</span>
            <span id="meter-cost" class="meter-cost">$0.00</span>
            <span id="meter-credits" class="meter-credits" hidden></span>
          </div>

          <!-- Candidate self-view. The proctor collector owns this stream; the camera
               indicator is unsuppressable, so we show the feed to keep it expected.
               Hidden until the collector attaches a stream at session start. -->
          <video id="self-view" class="self-view" autoplay playsinline muted hidden></video>

          <p id="caption" class="caption"></p>
        </section>

        <footer class="bar">
          <p id="status" class="status" data-state="idle">ready to start</p>
          <button id="talk-button" class="pulsantone" type="button" data-on="false">
            ⏹ Stop
          </button>
        </footer>
        <div id="toast" class="toast" hidden>
          <span id="toast-msg"></span>
        </div>
      </div>

      <!-- ── DONE ──────────────────────────────────────────────────────────────── -->
      <section class="screen panel" id="screen-done">
        <h2>Interview finished 🎉</h2>
        <p class="hint">The transcript has been saved.</p>
        <a id="transcript-link" class="btn primary" href="#">View transcript</a>
        <button type="button" id="btn-restart" class="btn">Start another</button>
      </section>
    </main>

    <script>
      import '../scripts/interview-client.ts';
    </script>

    <style>
      /* STRICT: the page never scrolls on the Y axis. */
      :global(html),
      :global(body) {
        height: 100%;
        margin: 0;
        overflow: hidden;
      }
      :global(body) {
        background: #0b0c10;
        color: #e8eaed;
        font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
      }

      .app {
        height: 100dvh;
        overflow: hidden;
      }

      /* Only the active screen is shown; each fills the viewport. */
      .screen {
        display: none;
        height: 100dvh;
      }
      .app[data-screen='start'] #screen-start,
      .app[data-screen='interview'] #screen-interview,
      .app[data-screen='done'] #screen-done {
        display: flex;
      }

      /* Centered panels (start / done). */
      .panel {
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 16px;
        padding: 24px;
        text-align: center;
      }
      .brand {
        margin: 0;
        font-size: 1.6rem;
      }
      .panel h2 {
        margin: 0;
        font-size: 1.25rem;
      }
      .hint {
        margin: 0;
        color: #9aa0aa;
        font-size: 0.9rem;
      }
      .error-line {
        margin: 0;
        min-height: 1.2em;
        color: #f87171;
        font-size: 0.85rem;
      }
      .admin-link {
        display: block;
        text-align: center;
        margin-top: 20px;
        font-size: 0.78rem;
        color: #4b5563;
        text-decoration: none;
      }
      .admin-link:hover { color: #9aa0aa; }

      /* Prompt / template selectors. */
      .selectors {
        display: flex;
        gap: 18px;
        margin-top: 4px;
      }
      .field {
        display: flex;
        flex-direction: column;
        gap: 6px;
        min-width: 220px;
        text-align: left;
      }
      .field-label {
        font-size: 0.8rem;
        color: #cbd5e1;
      }
      .select {
        padding: 10px 12px;
        font-size: 0.95rem;
        color: #e8eaed;
        background: #17181f;
        border: 1px solid #2a2c36;
        border-radius: 10px;
      }
      .select:disabled {
        opacity: 0.5;
      }

      .btn {
        padding: 11px 22px;
        font-size: 1rem;
        font-weight: 700;
        color: #e8eaed;
        background: #24262f;
        border: 1px solid #2a2c36;
        border-radius: 999px;
        cursor: pointer;
        text-decoration: none;
        transition: filter 0.15s ease;
      }
      .btn:hover {
        filter: brightness(1.12);
      }
      .btn.primary {
        color: #04150f;
        background: #10b981;
        border-color: transparent;
      }
      .btn:disabled {
        opacity: 0.5;
        cursor: default;
      }

      /* Interview screen: fixed top bar, stage fills, fixed bottom bar. */
      .interview {
        flex-direction: column;
      }
      .topbar {
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 12px;
        padding: 10px 18px calc(10px);
        padding-top: calc(10px + env(safe-area-inset-top, 0px));
        border-bottom: 1px solid #1b1d24;
      }
      .timer {
        font-size: 1.15rem;
        font-weight: 800;
        font-variant-numeric: tabular-nums;
        color: #a7f3d0;
      }
      .timer[data-warn='warn'] {
        color: #fbbf24;
      }
      .timer[data-warn='critical'] {
        color: #f87171;
      }

      .stage {
        position: relative;
        flex: 1;
        min-height: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        padding: 16px;
      }
      #avatar-video {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
        border-radius: 20px;
        background: #000;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
      }

      .meter {
        position: absolute;
        top: 22px;
        left: 22px;
        display: flex;
        align-items: baseline;
        gap: 8px;
        padding: 8px 14px;
        font-size: 0.95rem;
        font-variant-numeric: tabular-nums;
        color: #e8eaed;
        background: rgba(11, 12, 16, 0.66);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 999px;
        backdrop-filter: blur(8px);
        pointer-events: none;
      }
      .meter[hidden] {
        display: none;
      }
      .meter-icon {
        font-size: 0.85rem;
      }
      .meter-cost {
        font-weight: 700;
        color: #a7f3d0;
      }
      .meter-credits {
        color: #9aa0aa;
        font-size: 0.8rem;
      }
      .meter-credits[hidden] {
        display: none;
      }
      .meter-credits[data-low='true'] {
        color: #fbbf24;
      }
      .meter-credits[data-low='critical'] {
        color: #f87171;
      }

      .caption {
        position: absolute;
        bottom: 14px;
        left: 50%;
        transform: translateX(-50%);
        max-width: min(80%, 720px);
        margin: 0;
        padding: 6px 14px;
        font-size: 0.9rem;
        color: #cbd5e1;
        background: rgba(11, 12, 16, 0.6);
        border-radius: 10px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        pointer-events: none;
      }
      .caption:empty {
        display: none;
      }

      /* Small mirrored self-view in the corner (the camera indicator is unsuppressable,
         so we keep the feed visible and expected). Hidden until a stream is attached. */
      .self-view {
        position: absolute;
        right: 22px;
        bottom: 22px;
        width: 132px;
        height: 99px;
        object-fit: cover;
        border-radius: 12px;
        background: #000;
        border: 1px solid rgba(255, 255, 255, 0.14);
        box-shadow: 0 6px 20px rgba(0, 0, 0, 0.5);
        transform: scaleX(-1);
        pointer-events: none;
        z-index: 2;
      }
      .self-view[hidden] {
        display: none;
      }

      .bar {
        flex-shrink: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 10px;
        padding: 12px 16px calc(16px + env(safe-area-inset-bottom, 0px));
      }
      .status {
        margin: 0;
        font-size: 0.9rem;
        letter-spacing: 0.02em;
        color: #9aa0aa;
        min-height: 1.2em;
      }
      .status[data-state='listening'] {
        color: #4ea1ff;
      }
      .status[data-state='speaking'] {
        color: #34d399;
      }
      .status[data-state='ready'] {
        color: #a7f3d0;
      }
      .status[data-state='connecting'] {
        color: #fbbf24;
      }
      .status[data-state='waiting'] {
        color: #fbbf24;
      }
      .status[data-state='error'] {
        color: #f87171;
      }

      .pulsantone {
        --accent: #ef4444;
        min-width: 240px;
        padding: 16px 40px;
        font-size: 1.3rem;
        font-weight: 700;
        color: #fff;
        background: var(--accent);
        border: none;
        border-radius: 999px;
        cursor: pointer;
        transition: transform 0.08s ease, filter 0.15s ease, background 0.15s ease;
        box-shadow: 0 8px 24px rgba(239, 68, 68, 0.35);
      }
      .pulsantone:hover {
        filter: brightness(1.06);
      }
      .pulsantone:active {
        transform: translateY(1px);
      }
      .pulsantone:disabled {
        opacity: 0.6;
        cursor: default;
        box-shadow: none;
      }

      /* Segmented provider toggle + consent (shared with the start screen). */
      .provider-toggle {
        display: inline-flex;
        padding: 3px;
        background: #17181f;
        border: 1px solid #2a2c36;
        border-radius: 999px;
      }
      .provider-toggle label {
        cursor: pointer;
      }
      .provider-toggle input {
        position: absolute;
        opacity: 0;
        pointer-events: none;
      }
      .provider-toggle span {
        display: inline-block;
        padding: 6px 18px;
        font-size: 0.9rem;
        font-weight: 600;
        color: #9aa0aa;
        border-radius: 999px;
        transition: background 0.15s ease, color 0.15s ease;
      }
      .provider-toggle input:checked + span {
        color: #04150f;
        background: #10b981;
      }
      .consent {
        display: flex;
        align-items: flex-start;
        gap: 8px;
        max-width: 520px;
        font-size: 0.78rem;
        line-height: 1.35;
        color: #9aa0aa;
        cursor: pointer;
        text-align: left;
      }
      .consent input {
        margin-top: 2px;
        accent-color: #10b981;
        flex-shrink: 0;
      }

      .toast {
        position: fixed;
        top: 16px;
        left: 50%;
        transform: translateX(-50%);
        padding: 10px 18px;
        font-size: 0.88rem;
        font-weight: 600;
        color: #fff;
        background: rgba(239, 68, 68, 0.92);
        border-radius: 999px;
        backdrop-filter: blur(8px);
        box-shadow: 0 4px 16px rgba(0,0,0,0.4);
        z-index: 200;
        pointer-events: none;
        white-space: nowrap;
      }
      .toast[hidden] {
        display: none;
      }
    </style>
  </body>
</html>
