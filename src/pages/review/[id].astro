---
// Simple review view for a stored interview: the transcript plus an estimated cost
// recomputed from the session duration × the provider rate (the comparison metric).
import { computeIntegritySummary, getIntegrityEvents, getSession, getSnapshots, getUtterances } from '../../lib/db';
import type { SnapshotRow } from '../../lib/db';
import { rates } from '../../lib/pricing';
import { INTEGRITY_LABELS, type IntegrityType } from '../../lib/proctor-config';
import { resolveLocale, t, LOCALE_COOKIE, type Locale } from '../../lib/i18n';

const locale: Locale = resolveLocale(
  Astro.cookies.get(LOCALE_COOKIE)?.value,
  Astro.request.headers.get('accept-language'),
);

const id = Number(Astro.params.id);
const session = Number.isInteger(id) ? getSession(id) : undefined;
const utterances = session ? getUtterances(id) : [];

let durationMin = 0;
let costUsd = 0;
if (session?.ended_at) {
  durationMin =
    (new Date(session.ended_at).getTime() - new Date(session.started_at).getTime()) / 60_000;
  costUsd =
    session.provider === 'heygen'
      ? durationMin * rates.heygenCreditsPerMin * rates.heygenUsdPerCredit
      : Math.max(0.5, Math.ceil(durationMin * 600) / 600) * rates.tavusUsdPerMin;
}

// Soft-proctoring integrity: raw event timeline + derived risk band (query-time, no
// stored column — same approach as the cost estimate above).
const integrityEvents = session ? getIntegrityEvents(id) : [];
const integrity = session ? computeIntegritySummary(id) : null;
const snapshots: SnapshotRow[] = session ? getSnapshots(id) : [];
const BAND_LABEL: Record<string, string> = {
  low: t(locale, 'review.band.low'),
  medium: t(locale, 'review.band.medium'),
  high: t(locale, 'review.band.high'),
};

const timeFmt = new Intl.DateTimeFormat(locale, { timeStyle: 'medium' });
const dateFmt = new Intl.DateTimeFormat(locale, { dateStyle: 'medium', timeStyle: 'short' });

function eventTime(ts: string): string {
  const d = new Date(ts);
  return Number.isNaN(d.getTime()) ? ts : timeFmt.format(d);
}
function eventDetail(type: string, metaJson: string | null): string {
  if (!metaJson) return '';
  let meta: Record<string, unknown> = {};
  try {
    meta = JSON.parse(metaJson) as Record<string, unknown>;
  } catch {
    return '';
  }
  const parts: string[] = [];
  if (typeof meta.durationMs === 'number') parts.push(`${(meta.durationMs / 1000).toFixed(1)}s`);
  if (type === 'multiple_faces' && typeof meta.count === 'number')
    parts.push(t(locale, 'review.detail.faces', { n: meta.count }));
  if (type === 'looking_away' && typeof meta.yaw === 'number')
    parts.push(t(locale, 'review.detail.yaw', { n: meta.yaw }));
  return parts.join(' · ');
}
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{t(locale, 'review.title', { id })}</title>
  </head>
  <body>
    <main>
      {!session && <p class="empty">{t(locale, 'review.not_found', { id })}</p>}
      {
        session && (
          <>
            <header>
              <h1>{t(locale, 'review.heading', { id: session.id })}</h1>
              <p class="meta">
                <span class="badge">{session.provider}</span>
                {session.ended_reason && <span>· {session.ended_reason}</span>}
                <span>· {t(locale, 'review.started', { ts: dateFmt.format(new Date(session.started_at)) })}</span>
                {session.ended_at && <span>· {t(locale, 'review.ended', { ts: dateFmt.format(new Date(session.ended_at)) })}</span>}
                {session.ended_at && (
                  <span class="cost">
                    · ≈ ${costUsd.toFixed(2)} ({durationMin.toFixed(1)} min)
                  </span>
                )}
              </p>
            </header>

            {integrity && (
              <section class="integrity">
                <div class="integrity-head">
                  <h2>{t(locale, 'review.integrity.title')}</h2>
                  <span class={`band band-${integrity.band}`}>
                    {t(locale, 'review.integrity.risk', { band: BAND_LABEL[integrity.band], score: integrity.score })}
                  </span>
                </div>
                {integrity.total === 0 ? (
                  <p class="empty">{t(locale, 'review.integrity.none')}</p>
                ) : (
                  <ol class="events">
                    {integrityEvents.map((e) => (
                      <li class="event">
                        <span class="ev-label">
                          {INTEGRITY_LABELS[e.type as IntegrityType] ?? e.type}
                        </span>
                        <span class="ev-detail">{eventDetail(e.type, e.meta)}</span>
                        <span class="ev-time">{eventTime(e.ts)}</span>
                      </li>
                    ))}
                  </ol>
                )}
              </section>
            )}

            {snapshots.length > 0 && (
              <section class="snapshots">
                <h2>{t(locale, 'review.snapshots.title', { n: snapshots.length })}</h2>
                <div class="snap-grid">
                  {snapshots.map((s) => (
                    <div class="snap-item">
                      <span class="snap-time">{eventTime(s.ts)}</span>
                      <span class="snap-path">{s.path}</span>
                    </div>
                  ))}
                </div>
              </section>
            )}

            {utterances.length === 0 && <p class="empty">{t(locale, 'review.transcript.empty')}</p>}
            <ol class="transcript">
              {utterances.map((u) => (
                <li class={`turn ${u.role}`}>
                  <span class="who">{u.role === 'avatar' ? t(locale, 'review.speaker.avatar') : t(locale, 'review.speaker.you')}</span>
                  <span class="text">{u.text}</span>
                </li>
              ))}
            </ol>
          </>
        )
      }
    </main>

    <style>
      /* Quint brand accent (user-facing side). Sampled from the Quint logo. */
      :global(:root) {
        --brand: #7719af;
      }
      :global(body) {
        margin: 0;
        background: #0b0c10;
        color: #e8eaed;
        font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
      }
      main {
        max-width: 760px;
        margin: 0 auto;
        padding: 32px 20px 64px;
      }
      h1 {
        margin: 0 0 6px;
        font-size: 1.4rem;
      }
      .meta {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin: 0 0 24px;
        font-size: 0.85rem;
        color: #9aa0aa;
      }
      .badge {
        padding: 2px 10px;
        font-weight: 700;
        color: #fff;
        background: var(--brand);
        border-radius: 999px;
        text-transform: uppercase;
        font-size: 0.72rem;
      }
      .cost {
        color: #a7f3d0;
      }

      /* Integrity panel */
      .integrity {
        margin: 0 0 28px;
        padding: 16px;
        border: 1px solid #2a2c36;
        border-radius: 12px;
        background: #101119;
      }
      .integrity-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 12px;
      }
      .integrity-head h2 {
        margin: 0;
        font-size: 1rem;
        letter-spacing: 0.02em;
      }
      .band {
        padding: 3px 12px;
        font-size: 0.74rem;
        font-weight: 700;
        border-radius: 999px;
        text-transform: uppercase;
      }
      .band-low {
        color: #04150f;
        background: var(--brand);
      }
      .band-medium {
        color: #1a1400;
        background: #fbbf24;
      }
      .band-high {
        color: #fff;
        background: #ef4444;
      }
      .events {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 6px;
      }
      .event {
        display: grid;
        grid-template-columns: 1fr auto auto;
        align-items: baseline;
        gap: 12px;
        padding: 6px 10px;
        border-radius: 8px;
        background: #17181f;
        font-size: 0.85rem;
      }
      .ev-label {
        font-weight: 600;
      }
      .ev-detail {
        color: #9aa0aa;
        font-variant-numeric: tabular-nums;
      }
      .ev-time {
        color: #6b7280;
        font-size: 0.78rem;
        font-variant-numeric: tabular-nums;
      }

      .transcript {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 12px;
      }
      .turn {
        display: flex;
        flex-direction: column;
        gap: 4px;
        padding: 12px 16px;
        border-radius: 12px;
        background: #17181f;
        border: 1px solid #2a2c36;
      }
      .turn.avatar {
        border-left: 3px solid var(--brand);
      }
      .turn.user {
        border-left: 3px solid #4ea1ff;
      }
      .who {
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: #9aa0aa;
      }
      .text {
        line-height: 1.4;
      }
      .empty {
        color: #9aa0aa;
      }

      .snapshots {
        margin: 0 0 28px;
        padding: 16px;
        border: 1px solid #2a2c36;
        border-radius: 12px;
        background: #101119;
      }
      .snapshots h2 {
        margin: 0 0 12px;
        font-size: 1rem;
      }
      .snap-grid {
        display: flex;
        flex-direction: column;
        gap: 4px;
      }
      .snap-item {
        display: flex;
        gap: 12px;
        padding: 4px 8px;
        font-size: 0.8rem;
        background: #17181f;
        border-radius: 6px;
      }
      .snap-time {
        color: #9aa0aa;
        flex-shrink: 0;
      }
      .snap-path {
        color: #6b7280;
        font-family: monospace;
      }
    </style>
  </body>
</html>
