---
// Session review: the stored transcript plus an estimated cost recomputed from the
// session duration × the provider rate (the comparison metric). Rendered inside the
// shared admin chrome (light theme, working nav) with a back link to the archive.
import AdminLayout from '../../layouts/AdminLayout.astro';
import { computeIntegritySummary, getIntegrityEvents, getSession, getSnapshots, getUtterances } from '../../lib/db';
import type { SnapshotRow } from '../../lib/db';
import { rates } from '../../lib/pricing';
import { INTEGRITY_LABELS, type IntegrityType } from '../../lib/proctor-config';
import { resolveLocale, t, LOCALE_COOKIE, type Locale } from '../../lib/i18n';

export const prerender = false;

const locale: Locale = resolveLocale(
  Astro.cookies.get(LOCALE_COOKIE)?.value,
  Astro.request.headers.get('accept-language'),
);

const id = Number(Astro.params.id);
const session = Number.isInteger(id) ? getSession(id) : undefined;
const utterances = session ? getUtterances(id) : [];

let durationMin = 0;
let costUsd = 0;
if (session?.ended_at) {
  durationMin =
    (new Date(session.ended_at).getTime() - new Date(session.started_at).getTime()) / 60_000;
  costUsd =
    session.provider === 'heygen'
      ? durationMin * rates.heygenCreditsPerMin * rates.heygenUsdPerCredit
      : Math.max(0.5, Math.ceil(durationMin * 600) / 600) * rates.tavusUsdPerMin;
}

// Soft-proctoring integrity: raw event timeline + derived risk band (query-time, no
// stored column — same approach as the cost estimate above).
const integrityEvents = session ? getIntegrityEvents(id) : [];
const integrity = session ? computeIntegritySummary(id) : null;
const snapshots: SnapshotRow[] = session ? getSnapshots(id) : [];
const BAND_LABEL: Record<string, string> = {
  low: t(locale, 'review.band.low'),
  medium: t(locale, 'review.band.medium'),
  high: t(locale, 'review.band.high'),
};
// Semantic band styling in the light palette (green / amber / red).
const BAND_CLASS: Record<string, string> = {
  low: 'bg-success-soft text-success',
  medium: 'bg-warning/15 text-warning',
  high: 'bg-danger-soft text-danger',
};

const timeFmt = new Intl.DateTimeFormat(locale, { timeStyle: 'medium' });
const dateFmt = new Intl.DateTimeFormat(locale, { dateStyle: 'medium', timeStyle: 'short' });

function eventTime(ts: string): string {
  const d = new Date(ts);
  return Number.isNaN(d.getTime()) ? ts : timeFmt.format(d);
}
function eventDetail(type: string, metaJson: string | null): string {
  if (!metaJson) return '';
  let meta: Record<string, unknown> = {};
  try {
    meta = JSON.parse(metaJson) as Record<string, unknown>;
  } catch {
    return '';
  }
  const parts: string[] = [];
  if (typeof meta.durationMs === 'number') parts.push(`${(meta.durationMs / 1000).toFixed(1)}s`);
  if (type === 'multiple_faces' && typeof meta.count === 'number')
    parts.push(t(locale, 'review.detail.faces', { n: meta.count }));
  if (type === 'looking_away' && typeof meta.yaw === 'number')
    parts.push(t(locale, 'review.detail.yaw', { n: meta.yaw }));
  return parts.join(' · ');
}
---

<AdminLayout section="sessions" title={t(locale, 'review.title', { id })}>
  <a
    href="/admin/sessions"
    class="mb-6 inline-flex items-center gap-1.5 text-sm font-medium text-muted transition-colors hover:text-accent"
  >
    <span aria-hidden="true">&larr;</span> {t(locale, 'review.back_to_sessions')}
  </a>

  {!session && <p class="text-muted">{t(locale, 'review.not_found', { id })}</p>}
  {
    session && (
      <>
        <header class="mb-8">
          <h1 class="text-2xl font-semibold tracking-tight">{t(locale, 'review.heading', { id: session.id })}</h1>
          <p class="mt-2 flex flex-wrap items-center gap-2 text-sm text-muted">
            <span class="badge bg-accent uppercase text-accent-fg">{session.provider}</span>
            {session.ended_reason && <span>· {session.ended_reason}</span>}
            <span>· {t(locale, 'review.started', { ts: dateFmt.format(new Date(session.started_at)) })}</span>
            {session.ended_at && <span>· {t(locale, 'review.ended', { ts: dateFmt.format(new Date(session.ended_at)) })}</span>}
            {session.ended_at && (
              <span class="font-medium text-success">
                · &asymp; ${costUsd.toFixed(2)} ({durationMin.toFixed(1)} min)
              </span>
            )}
          </p>
        </header>

        {integrity && (
          <section class="card mb-7 p-5">
            <div class="mb-3 flex items-center justify-between gap-3">
              <h2 class="text-base font-semibold">{t(locale, 'review.integrity.title')}</h2>
              <span class={`badge uppercase ${BAND_CLASS[integrity.band] ?? 'badge-off'}`}>
                {t(locale, 'review.integrity.risk', { band: BAND_LABEL[integrity.band], score: integrity.score })}
              </span>
            </div>
            {integrity.total === 0 ? (
              <p class="text-sm text-muted">{t(locale, 'review.integrity.none')}</p>
            ) : (
              <ol class="flex flex-col gap-1.5">
                {integrityEvents.map((e) => (
                  <li class="grid grid-cols-[1fr_auto_auto] items-baseline gap-3 rounded-md bg-panel px-3 py-1.5 text-sm">
                    <span class="font-medium text-fg">
                      {INTEGRITY_LABELS[e.type as IntegrityType] ?? e.type}
                    </span>
                    <span class="tabular-nums text-muted">{eventDetail(e.type, e.meta)}</span>
                    <span class="text-xs tabular-nums text-faint">{eventTime(e.ts)}</span>
                  </li>
                ))}
              </ol>
            )}
          </section>
        )}

        {snapshots.length > 0 && (
          <section class="card mb-7 p-5">
            <h2 class="mb-3 text-base font-semibold">{t(locale, 'review.snapshots.title', { n: snapshots.length })}</h2>
            <!-- Responsive grid: fills N columns per row (no horizontal scroll); each tile
                 carries an event tag (or "timed") and the capture time. -->
            <div class="grid grid-cols-[repeat(auto-fill,minmax(9rem,1fr))] gap-3">
              {snapshots.map((s) => (
                <figure class="group relative">
                  <img
                    src={`/api/snapshot/${s.path}`}
                    alt={s.trigger ? INTEGRITY_LABELS[s.trigger as IntegrityType] : t(locale, 'review.snapshots.timed')}
                    loading="lazy"
                    class="h-24 w-full rounded-md border border-border object-cover"
                  />
                  <figcaption class="absolute inset-x-0 bottom-0 flex items-center justify-between gap-1 rounded-b-md bg-black/65 px-1.5 py-1 text-[10px] leading-tight text-white">
                    <span class={`truncate font-medium ${s.trigger ? 'text-danger-soft' : ''}`}>
                      {s.trigger ? INTEGRITY_LABELS[s.trigger as IntegrityType] : t(locale, 'review.snapshots.timed')}
                    </span>
                    <span class="shrink-0 tabular-nums opacity-90">{eventTime(s.ts)}</span>
                  </figcaption>
                </figure>
              ))}
            </div>
          </section>
        )}

        {utterances.length === 0 && <p class="text-sm text-muted">{t(locale, 'review.transcript.empty')}</p>}
        <ol class="flex flex-col gap-3">
          {utterances.map((u) => (
            <li
              class:list={[
                'flex flex-col gap-1 rounded-lg border border-border bg-surface px-4 py-3',
                u.role === 'avatar' ? 'border-l-[3px] border-l-accent' : 'border-l-[3px] border-l-border-strong',
              ]}
            >
              <span class="text-xs uppercase tracking-wide text-faint">
                {u.role === 'avatar' ? t(locale, 'review.speaker.avatar') : t(locale, 'review.speaker.you')}
              </span>
              <span class="leading-relaxed text-fg">{u.text}</span>
            </li>
          ))}
        </ol>
      </>
    )
  }
</AdminLayout>
